#!/usr/bin/env bash
# Daily pg_dump of both NeuraMD databases on AIrch.
# Keeps 30 days of custom-format archives under /home/rafael/backups.
# Invoked by neuramd-backup.timer at 03:00 local time.

set -euo pipefail

BACKUP_DIR="/home/rafael/backups"
RETENTION_DAYS=30
STAMP=$(date +%Y%m%d-%H%M%S)

mkdir -p "$BACKUP_DIR"

for db in neura_md_production neura_md_legacy; do
	dest="$BACKUP_DIR/${db}-${STAMP}.dump"
	# pg_hba uses trust on 127.0.0.1, so no password prompt.
	pg_dump -h 127.0.0.1 -U postgres -Fc -f "$dest" "$db"
	size=$(du -h "$dest" | cut -f1)
	echo "pg_dump: $db -> $dest ($size)"
done

# Prune dumps older than retention window (by mtime)
find "$BACKUP_DIR" -type f -name '*.dump' -mtime +$RETENTION_DAYS -print -delete

echo "backup done: $(date --iso-8601=seconds)"
