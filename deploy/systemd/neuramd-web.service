[Unit]
Description=NeuraMD Rails (puma) on AIrch
After=network-online.target postgresql.service
Wants=network-online.target
Requires=postgresql.service

[Service]
Type=simple
User=rafael
Group=rafael
WorkingDirectory=/home/rafael/apps/NeuraMD
Environment=RAILS_ENV=production
Environment=PORT=3000
Environment=RAILS_MAX_THREADS=3
Environment=WEB_CONCURRENCY=0
Environment=RAILS_LOG_TO_STDOUT=1
Environment=RAILS_SERVE_STATIC_FILES=1
Environment=POSTGRES_USER=postgres
Environment=POSTGRES_HOST=127.0.0.1
Environment=POSTGRES_PORT=5432
Environment=NEURAMD_DATABASE=neura_md_production
Environment=NEURAMD_CACHE_DATABASE=neura_md_production_cache
Environment=NEURAMD_QUEUE_DATABASE=neura_md_production_queue
Environment=NEURAMD_LEGACY_DATABASE=neura_md_legacy
Environment=NEURAMD_TENTACLES_ENABLED=1
Environment=PATH=/home/rafael/.local/share/mise/shims:/home/rafael/.local/bin:/usr/local/bin:/usr/bin
ExecStart=/home/rafael/.local/share/mise/shims/bundle exec puma -C config/puma.rb
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=neuramd-web

# Tentacle cwd whitelist. To let tentacles boot under a different repo
# root (cron jobs or manual sessions with tentacle_cwd set), set the env
# and ALSO append the matching `<root>/tmp/tentacles` path to
# ReadWritePaths — WorktreeService.ensure writes there and will fail
# silently under ProtectHome=read-only otherwise. Leaving it unset keeps
# the compiled default in Tentacles::BootConfig::DEFAULT_CWD_ALLOWED_PREFIXES.
# Environment=NEURAMD_TENTACLE_CWD_ROOTS=/home/rafael/projects/

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/home/rafael/apps/NeuraMD/tmp /home/rafael/apps/NeuraMD/log /home/rafael/apps/NeuraMD/storage /home/rafael/apps/NeuraMD/.git /home/rafael/.claude

[Install]
WantedBy=multi-user.target
