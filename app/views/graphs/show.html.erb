<% content_for :title, "Grafo — NeuraMD" %>
<% content_for :full_bleed, true %>
<% content_for :hide_app_nav, true %>

<section class="nm-graph nm-graph--fullscreen"
         data-controller="graph"
         data-graph-data-url-value="<%= api_graph_path %>">
  <div class="nm-graph__stage nm-graph__stage--fullscreen">
    <div class="nm-graph__canvas-wrap nm-graph__canvas-wrap--fullscreen">
      <div class="nm-graph__sigma-host" data-graph-target="graphHost"></div>
      <div class="nm-graph__tooltip-layer" data-graph-target="tooltipLayer"></div>
    </div>

    <div class="nm-graph__left-rail">
      <header class="nm-graph__floating nm-graph__floating--top-left">
        <h1 class="nm-graph__title">NeuraMD</h1>
        <div class="nm-graph__header-actions">
          <%= button_to "Nova nota",
              notes_path,
              method: :post,
              params: { note: { title: "Nova nota" } },
              class: "nm-graph__primary-btn",
              form: { data: { action: "submit->page-transition#submit", transition_kind: "graph-to-note" } } %>
          <button type="button" class="nm-graph__ghost-btn" data-action="click->note-finder#open">Buscar</button>
          <%= link_to "IA Ops", ai_requests_dashboard_path, class: "nm-graph__ghost-btn" %>
        </div>
      </header>

      <aside class="nm-graph__floating nm-graph__floating--left">
        <div class="nm-graph__panel-head nm-graph__panel-head--interactive">
          <button type="button"
                  class="nm-graph__panel-title-button"
                  data-graph-target="tagTitle"
                  data-action="click->graph#openTagSearch">
            Tags
          </button>
          <input type="search"
                 class="nm-graph__panel-search"
                 placeholder="Buscar tags..."
                 hidden
                 data-graph-target="tagSearch"
                 data-action="input->graph#updateTagSearch blur->graph#closeTagSearch keydown->graph#handleTagSearchKeydown">
        </div>
        <div class="nm-graph__tag-list" data-graph-target="tagList"></div>
      </aside>
    </div>

    <aside class="nm-graph__floating nm-graph__floating--right">
      <section class="nm-graph__panel">
        <div class="nm-graph__panel-head">
          <h2>Controles</h2>
          <button type="button" class="nm-graph__ghost-btn" data-action="graph#resetFocus">Limpar</button>
        </div>

        <div class="nm-graph__meta" data-graph-target="meta">Carregando dataset...</div>

        <label class="nm-graph__field">
          <span>Buscar nota</span>
          <input type="search"
                 placeholder="Titulo ou resumo"
                 data-graph-target="search"
                 data-action="input->graph#updateSearch">
        </label>

        <label class="nm-graph__field">
          <span>Profundidade</span>
          <select data-graph-target="focusDepth" data-action="change->graph#updateDepth">
            <option value="1">1 salto</option>
            <option value="2">2 saltos</option>
            <option value="3" selected>3 saltos</option>
            <option value="4">4 saltos</option>
          </select>
        </label>

      </section>

      <section class="nm-graph__panel">
        <div class="nm-graph__stack">
          <details class="nm-graph__dropdown">
            <summary class="nm-graph__dropdown-button">
              <span>Notas sem Link</span>
              <span class="nm-graph__dropdown-caret">+</span>
            </summary>
            <div class="nm-graph__dropdown-body">
              <div class="nm-graph__note-list" data-graph-target="linklessList"></div>
            </div>
          </details>
          <details class="nm-graph__dropdown">
            <summary class="nm-graph__dropdown-button">
              <span>Notas Futuras</span>
              <span class="nm-graph__dropdown-caret">+</span>
            </summary>
            <div class="nm-graph__dropdown-body">
              <div class="nm-graph__note-list" data-graph-target="promiseList"></div>
            </div>
          </details>
        </div>
      </section>

      <section class="nm-graph__panel">
        <div class="nm-graph__panel-head">
          <h2>Hierarquia</h2>
        </div>
        <label class="nm-graph__check">
          <input type="checkbox" value="target_is_parent" checked data-action="change->graph#toggleRole">
          <span>Target e pai</span>
        </label>
        <label class="nm-graph__check">
          <input type="checkbox" value="target_is_child" checked data-action="change->graph#toggleRole">
          <span>Target e filho</span>
        </label>
        <label class="nm-graph__check">
          <input type="checkbox" value="same_level" checked data-action="change->graph#toggleRole">
          <span>Mesmo nivel</span>
        </label>
        <label class="nm-graph__check">
          <input type="checkbox" value="null" checked data-action="change->graph#toggleRole">
          <span>Sem classificacao</span>
        </label>
      </section>

      <section class="nm-graph__panel nm-graph__panel--compact">
        <div class="nm-graph__panel-head">
          <h2>Sessao</h2>
        </div>
        <p class="nm-graph__session-email"><%= current_user.email %></p>
        <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "nm-graph__ghost-btn nm-graph__ghost-btn--danger" %>
      </section>
    </aside>

    <div class="nm-graph__empty hidden" data-graph-target="empty">
      Nenhum elemento permaneceu visivel com os filtros atuais.
    </div>
    <div class="nm-graph__error hidden" data-graph-target="error"></div>
  </div>
</section>
