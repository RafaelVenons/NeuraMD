<% main_note_slug = file_import.completed? && file_import.created_notes_data.present? ? file_import.created_notes_data.first["slug"] : nil %>
<%= tag.send(main_note_slug ? :a : :div,
      class: "fi-status fi-status--#{file_import.status}",
      href: main_note_slug ? "/app/notes/#{main_note_slug}" : nil,
      **( file_import.processing? ? {
        data: {
          controller: "file-import-poll",
          "file-import-poll-url-value": file_import_path(file_import),
          "file-import-poll-interval-value": "3000"
        }
      } : {} )
    ) do %>
  <div class="fi-status__badge"><%= file_import.status.humanize %></div>

  <% case file_import.status %>
  <% when "pending" %>
    <p class="fi-status__text">Aguardando processamento...</p>
  <% when "converting" %>
    <p class="fi-status__text">Convertendo arquivo para markdown...</p>
  <% when "enriching" %>
    <p class="fi-status__text">Enriquecendo formatacao e adicionando links...</p>
  <% when "analyzing" %>
    <p class="fi-status__text">Analisando estrutura com IA...</p>
  <% when "preview" %>
    <p class="fi-status__text">
      Preview: <strong><%= file_import.suggested_splits.size %></strong> nota(s) sugerida(s).
      Revise e confirme abaixo.
    </p>
  <% when "importing" %>
    <p class="fi-status__text">Criando notas no acervo...</p>
  <% when "completed" %>
    <p class="fi-status__text">
      Importacao concluida: <strong><%= file_import.notes_created %></strong> nota(s) criada(s).
    </p>
    <% if file_import.created_notes_data.present? %>
      <p class="fi-status__text">
        Nota principal: <strong><%= file_import.created_notes_data.first["title"] %></strong>
      </p>
    <% end %>
  <% when "failed" %>
    <% phase, message = parse_error_phase(file_import.error_message) %>
    <p class="fi-status__text fi-status__text--error">
      <strong>Falhou na etapa: <%= phase %></strong><br>
      <%= message %>
    </p>
  <% end %>

  <% if file_import.started_at %>
    <p class="fi-status__time">
      Iniciado: <%= file_import.started_at.strftime("%d/%m %H:%M") %>
      <% if file_import.completed_at %>
        — Concluido: <%= file_import.completed_at.strftime("%d/%m %H:%M") %>
        (<%= ((file_import.completed_at - file_import.started_at).round) %>s)
      <% end %>
    </p>
  <% end %>
<% end %>
