<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "NeuraMD" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="NeuraMD">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= image_path("logo/favicon.png") %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= image_path("logo/favicon.png") %>">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="nm-app font-sans">
    <% if notice.present? %>
      <div class="mx-auto max-w-4xl mt-4 px-4">
        <div class="nm-app-flash__message nm-app-flash__message--notice"
             data-controller="flash"
             data-flash-delay-value="2600">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="mx-auto max-w-4xl mt-4 px-4">
        <div class="nm-app-flash__message nm-app-flash__message--alert">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="nm-app-main container mx-auto max-w-6xl px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
