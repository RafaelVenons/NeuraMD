<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "NeuraMD" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="NeuraMD">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= image_path("logo/favicon.png") %>" type="image/png">
    <link rel="apple-touch-icon" href="<%= image_path("logo/favicon.png") %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= content_for?(:full_bleed) ? 'nm-app nm-app--immersive font-sans' : 'nm-app font-sans' %>"
        data-controller="page-transition note-finder"
        data-note-finder-search-url-value="<%= search_notes_path %>">
    <% unless content_for?(:hide_app_nav) %>
      <nav class="nm-app-nav">
        <a href="<%= root_path %>" class="nm-app-nav__brand">NeuraMD</a>
        <% if user_signed_in? %>
          <div class="nm-app-nav__actions">
            <a href="<%= graph_path %>" class="nm-app-nav__link">Grafo</a>
            <button type="button"
                    class="nm-app-nav__link"
                    title="Buscar notas (Ctrl+Shift+K)"
                    data-action="click->note-finder#open">
              Buscar
            </button>
            <span class="nm-app-nav__user"><%= current_user.email %></span>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "nm-app-nav__logout" %>
          </div>
        <% end %>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="<%= content_for?(:full_bleed) ? 'nm-app-flash nm-app-flash--immersive' : 'mx-auto max-w-4xl mt-4 px-4' %>">
        <div class="nm-app-flash__message nm-app-flash__message--notice"
             data-controller="flash"
             data-flash-delay-value="2600">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="<%= content_for?(:full_bleed) ? 'nm-app-flash nm-app-flash--immersive' : 'mx-auto max-w-4xl mt-4 px-4' %>">
        <div class="nm-app-flash__message nm-app-flash__message--alert">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="<%= content_for?(:full_bleed) ? 'nm-app-main nm-app-main--fullbleed' : 'nm-app-main container mx-auto max-w-6xl px-4 py-6' %>">
      <%= yield %>
    </main>

    <%= render "shared/note_finder" %>
  </body>
</html>
