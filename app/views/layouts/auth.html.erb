<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>NeuraMD</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="UTF-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="<%= image_path("logo/favicon.png") %>" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <%# Logo / brand %>
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2">
          <span class="text-2xl font-bold text-white tracking-tight">Neura<span class="text-blue-400">MD</span></span>
        </a>
        <p class="mt-1 text-xs text-gray-500">Self-hosted markdown notes</p>
      </div>

      <%# Flash messages %>
      <% if notice.present? %>
        <div class="mb-4 rounded-lg bg-green-900/40 border border-green-700 px-4 py-3 text-sm text-green-300">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 rounded-lg bg-red-900/40 border border-red-700 px-4 py-3 text-sm text-red-300">
          <%= alert %>
        </div>
      <% end %>

      <%# Card %>
      <div class="rounded-2xl border border-gray-800 bg-gray-900 shadow-2xl p-8">
        <%= yield %>
      </div>
    </div>
  </body>
</html>
