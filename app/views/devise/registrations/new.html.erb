<div class="nm-auth-form">
  <p class="nm-auth-form__eyebrow">Conta nova</p>
  <h1 class="nm-auth-form__title">Criar conta</h1>
  <p class="nm-auth-form__subtitle">Crie o usuario e caia direto na visualizacao principal do grafo.</p>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-4">
      <div>
        <%= f.label :email, "E-mail", class: "nm-auth-form__label" %>
        <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "nm-auth-form__input",
            placeholder: "voce@exemplo.com" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "nm-auth-form__label" %>
        <% if @minimum_password_length %>
          <p class="nm-auth-form__hint">Minimo <%= @minimum_password_length %> caracteres</p>
        <% end %>
        <%= f.password_field :password,
            autocomplete: "new-password",
            class: "nm-auth-form__input",
            placeholder: "••••••••" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar senha", class: "nm-auth-form__label" %>
        <%= f.password_field :password_confirmation,
            autocomplete: "new-password",
            class: "nm-auth-form__input",
            placeholder: "••••••••" %>
      </div>

      <%= f.submit "Criar conta", class: "nm-auth-form__submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
