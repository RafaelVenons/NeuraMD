<h1 class="text-xl font-semibold text-white mb-6">Criar conta</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="space-y-4">
    <div>
      <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-400 mb-1.5" %>
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          class: "block w-full rounded-lg bg-gray-800 border border-gray-700 px-3.5 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
          placeholder: "voce@exemplo.com" %>
    </div>

    <div>
      <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-400 mb-1.5" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-gray-500 mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
      <% end %>
      <%= f.password_field :password,
          autocomplete: "new-password",
          class: "block w-full rounded-lg bg-gray-800 border border-gray-700 px-3.5 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
          placeholder: "••••••••" %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm font-medium text-gray-400 mb-1.5" %>
      <%= f.password_field :password_confirmation,
          autocomplete: "new-password",
          class: "block w-full rounded-lg bg-gray-800 border border-gray-700 px-3.5 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
          placeholder: "••••••••" %>
    </div>

    <%= f.submit "Criar conta",
        class: "w-full mt-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-500 active:bg-blue-700 cursor-pointer transition-colors" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
