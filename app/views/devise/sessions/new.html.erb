<h1 class="text-xl font-semibold text-white mb-6">Entrar</h1>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="space-y-4">
    <div>
      <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-400 mb-1.5" %>
      <%= f.email_field :email,
          autofocus: true,
          autocomplete: "email",
          class: "block w-full rounded-lg bg-gray-800 border border-gray-700 px-3.5 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
          placeholder: "voce@exemplo.com" %>
    </div>

    <div>
      <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-400 mb-1.5" %>
      <%= f.password_field :password,
          autocomplete: "current-password",
          class: "block w-full rounded-lg bg-gray-800 border border-gray-700 px-3.5 py-2.5 text-sm text-gray-100 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
          placeholder: "••••••••" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 cursor-pointer select-none">
        <%= f.check_box :remember_me, class: "rounded border-gray-600 bg-gray-800 text-blue-500 focus:ring-blue-500 focus:ring-offset-gray-900" %>
        <span class="text-sm text-gray-400">Lembrar de mim</span>
      </label>
    <% end %>

    <%= f.submit "Entrar",
        class: "w-full mt-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-500 active:bg-blue-700 cursor-pointer transition-colors" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
