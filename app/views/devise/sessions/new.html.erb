<div class="nm-auth-form">
  <p class="nm-auth-form__eyebrow">Acesso</p>
  <h1 class="nm-auth-form__title">Entrar</h1>
  <p class="nm-auth-form__subtitle">Abra seu workspace direto no grafo principal.</p>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, "E-mail", class: "nm-auth-form__label" %>
        <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            class: "nm-auth-form__input",
            placeholder: "voce@exemplo.com" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "nm-auth-form__label" %>
        <%= f.password_field :password,
            autocomplete: "current-password",
            class: "nm-auth-form__input",
            placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="nm-auth-form__check">
          <%= f.check_box :remember_me, class: "nm-auth-form__checkbox" %>
          <span>Lembrar de mim</span>
        </label>
      <% end %>

      <%= f.submit "Entrar", class: "nm-auth-form__submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
