<div class="nm-auth-links">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Ja tem conta? Entrar", new_session_path(resource_name), class: "nm-auth-links__link" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Criar conta", new_registration_path(resource_name), class: "nm-auth-links__link" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueci a senha", new_password_path(resource_name), class: "nm-auth-links__link nm-auth-links__link--muted" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Reenviar confirmacao", new_confirmation_path(resource_name), class: "nm-auth-links__link nm-auth-links__link--muted" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Reenviar desbloqueio", new_unlock_path(resource_name), class: "nm-auth-links__link nm-auth-links__link--muted" %>
  <% end %>
</div>
