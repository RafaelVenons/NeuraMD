<% content_for :title, "Tentáculo — #{@note.title} — NeuraMD" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "xterm", "data-turbo-track": "reload" %>
<% end %>

<div class="nm-tentacle"
     data-controller="tentacle"
     data-tentacle-tentacle-id-value="<%= @tentacle_id %>"
     data-tentacle-start-url-value="<%= note_tentacle_path(@note.slug, format: :json) %>"
     data-tentacle-stop-url-value="<%= note_tentacle_path(@note.slug, format: :json) %>"
     data-tentacle-csrf-value="<%= form_authenticity_token %>"
     data-tentacle-alive-value="<%= @session&.alive? || false %>">

  <header class="nm-tentacle__header">
    <div class="nm-tentacle__title">
      <h1><%= @note.title %></h1>
      <p class="nm-tentacle__meta">
        Worktree: <code><%= @worktree %></code>
        · <%= link_to "↗ Dashboard", tentacles_dashboard_path, class: "nm-tentacle__meta-link" %>
      </p>
    </div>
    <div class="nm-tentacle__actions">
      <label class="nm-tentacle__command">
        Comando
        <select data-tentacle-target="command">
          <option value="bash">bash</option>
          <option value="claude" selected>claude</option>
        </select>
      </label>
      <button type="button"
              class="nm-tentacle__btn nm-tentacle__btn--primary"
              data-tentacle-target="startButton"
              data-action="tentacle#start">
        Iniciar
      </button>
      <button type="button"
              class="nm-tentacle__btn"
              data-tentacle-target="stopButton"
              data-action="tentacle#stop"
              hidden>
        Encerrar
      </button>
      <span class="nm-tentacle__status" data-tentacle-target="status">idle</span>
    </div>
  </header>

  <div class="nm-tentacle__body">
    <aside class="nm-tentacle__todos"
           data-controller="tentacle-todos"
           data-tentacle-todos-url-value="<%= todos_note_tentacle_path(@note.slug, format: :json) %>"
           data-tentacle-todos-csrf-value="<%= form_authenticity_token %>">
      <header class="nm-tentacle__todos-header">
        <h2>Todos</h2>
        <span class="nm-tentacle__todos-status" data-tentacle-todos-target="status">—</span>
      </header>
      <ul class="nm-tentacle__todos-list" data-tentacle-todos-target="list"></ul>
      <form class="nm-tentacle__todos-form"
            data-action="submit->tentacle-todos#add">
        <input type="text"
               placeholder="Nova task…"
               data-tentacle-todos-target="input"
               autocomplete="off">
        <button type="submit" class="nm-tentacle__btn">Adicionar</button>
      </form>

      <details class="nm-tentacle__context">
        <summary>
          Contexto
          <span class="nm-tentacle__context-count">
            <%= @outgoing_links.size + @incoming_links.size %>
          </span>
        </summary>
        <% if @outgoing_links.any? %>
          <h3 class="nm-tentacle__context-heading">Outgoing</h3>
          <ul class="nm-tentacle__context-list">
            <% @outgoing_links.each do |link| %>
              <li>
                <span class="nm-tentacle__context-role">
                  <%= link.hier_role == "target_is_parent" ? "f:" :
                      link.hier_role == "target_is_child"  ? "c:" :
                      link.hier_role == "same_level"       ? "b:" : "—" %>
                </span>
                <%= link_to link.dst_note.title,
                            note_path(link.dst_note.slug),
                            class: "nm-tentacle__context-link",
                            target: "_blank",
                            rel: "noopener" %>
              </li>
            <% end %>
          </ul>
        <% end %>
        <% if @incoming_links.any? %>
          <h3 class="nm-tentacle__context-heading">Backlinks</h3>
          <ul class="nm-tentacle__context-list">
            <% @incoming_links.each do |link| %>
              <li>
                <span class="nm-tentacle__context-role">←</span>
                <%= link_to link.src_note.title,
                            note_path(link.src_note.slug),
                            class: "nm-tentacle__context-link",
                            target: "_blank",
                            rel: "noopener" %>
              </li>
            <% end %>
          </ul>
        <% end %>
        <% if @outgoing_links.empty? && @incoming_links.empty? %>
          <p class="nm-tentacle__context-empty">Nenhum wikilink ainda.</p>
        <% end %>
      </details>

      <details class="nm-tentacle__spawn">
        <summary>↳ Spawn child</summary>
        <%= form_with url: children_note_tentacle_path(@note.slug),
                      method: :post,
                      local: true,
                      class: "nm-tentacle__spawn-form",
                      html: {autocomplete: "off"} do |f| %>
          <%= f.text_field :title, placeholder: "Título do filho", required: true %>
          <%= f.text_area :description, placeholder: "Escopo (opcional)", rows: 2 %>
          <%= f.text_field :extra_tags, placeholder: "Tags extras (CSV)" %>
          <%= f.submit "Criar filho", class: "nm-tentacle__btn nm-tentacle__btn--primary" %>
        <% end %>
      </details>
    </aside>

    <div class="nm-tentacle__terminal" data-tentacle-target="terminal"></div>

    <aside class="nm-tentacle__inbox"
           data-controller="tentacle-inbox"
           data-tentacle-inbox-url-value="<%= inbox_note_tentacle_path(@note.slug, format: :json) %>"
           data-tentacle-inbox-deliver-url-value="<%= inbox_deliver_all_note_tentacle_path(@note.slug, format: :json) %>"
           data-tentacle-inbox-csrf-value="<%= form_authenticity_token %>">
      <header class="nm-tentacle__inbox-header">
        <h2>Inbox</h2>
        <span class="nm-tentacle__inbox-status" data-tentacle-inbox-target="status">—</span>
      </header>
      <ul class="nm-tentacle__inbox-list" data-tentacle-inbox-target="list"></ul>
      <p class="nm-tentacle__inbox-empty" data-tentacle-inbox-target="empty" hidden>
        Sem mensagens ainda.
      </p>
      <button type="button"
              class="nm-tentacle__btn"
              data-action="tentacle-inbox#deliverAll">
        Marcar todas entregues
      </button>
    </aside>
  </div>
</div>

<style>
  .nm-tentacle {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    background: #0b0b0b;
    color: #d4d4d4;
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .nm-tentacle__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    gap: 1rem;
  }
  .nm-tentacle__title h1 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }
  .nm-tentacle__meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.25rem 0 0;
  }
  .nm-tentacle__meta-link {
    color: #a5b4fc;
    text-decoration: none;
  }
  .nm-tentacle__meta-link:hover { text-decoration: underline; }
  .nm-tentacle__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nm-tentacle__command {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }
  .nm-tentacle__command select {
    background: #1a1a1a;
    color: #e5e5e5;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
  }
  .nm-tentacle__btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #e5e5e5;
    padding: 0.35rem 0.85rem;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .nm-tentacle__btn--primary {
    background: #4f46e5;
    border-color: #4f46e5;
  }
  .nm-tentacle__btn:hover { opacity: 0.85; }
  .nm-tentacle__status {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.7);
  }
  .nm-tentacle__body {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: 260px 1fr 280px;
  }
  .nm-tentacle__todos {
    display: flex;
    flex-direction: column;
    min-height: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.75rem 0.75rem 0.5rem;
    gap: 0.5rem;
  }
  .nm-tentacle__todos-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nm-tentacle__todos-header h2 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
  .nm-tentacle__todos-status {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
  }
  .nm-tentacle__todos-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .nm-tentacle__todo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.8rem;
    color: #e5e5e5;
  }
  .nm-tentacle__todo:hover { background: rgba(255, 255, 255, 0.04); }
  .nm-tentacle__todo input[type="checkbox"] { accent-color: #4f46e5; flex-shrink: 0; }
  .nm-tentacle__todo--done .nm-tentacle__todo-text {
    text-decoration: line-through;
    color: rgba(255, 255, 255, 0.45);
  }
  .nm-tentacle__todo-text {
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }
  .nm-tentacle__todo-remove {
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0 0.2rem;
  }
  .nm-tentacle__todo-remove:hover { color: #f87171; }
  .nm-tentacle__todos-form {
    display: flex;
    gap: 0.25rem;
  }
  .nm-tentacle__todos-form input {
    flex: 1;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #e5e5e5;
    border-radius: 0.25rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.8rem;
  }
  .nm-tentacle__todos-form input:focus {
    outline: none;
    border-color: #4f46e5;
  }
  .nm-tentacle__context {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }
  .nm-tentacle__context summary {
    cursor: pointer;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.04em;
    padding: 0.15rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nm-tentacle__context summary:hover { color: #a5b4fc; }
  .nm-tentacle__context-count {
    font-size: 0.65rem;
    padding: 0.05rem 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.55);
  }
  .nm-tentacle__context-heading {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
    margin: 0.6rem 0 0.25rem;
  }
  .nm-tentacle__context-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .nm-tentacle__context-list li {
    display: flex;
    gap: 0.35rem;
    font-size: 0.75rem;
    align-items: baseline;
  }
  .nm-tentacle__context-role {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.65rem;
    min-width: 1.2em;
    font-family: ui-monospace, monospace;
  }
  .nm-tentacle__context-link {
    color: #a5b4fc;
    text-decoration: none;
    word-break: break-word;
  }
  .nm-tentacle__context-link:hover { text-decoration: underline; }
  .nm-tentacle__context-empty {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0.4rem 0 0;
  }
  .nm-tentacle__spawn {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 0.5rem;
    margin-top: 0.25rem;
  }
  .nm-tentacle__spawn summary {
    cursor: pointer;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.04em;
    padding: 0.15rem 0;
  }
  .nm-tentacle__spawn summary:hover { color: #a5b4fc; }
  .nm-tentacle__spawn-form {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 0.4rem;
  }
  .nm-tentacle__spawn-form input[type="text"],
  .nm-tentacle__spawn-form textarea {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #e5e5e5;
    border-radius: 0.25rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.75rem;
    font-family: inherit;
    resize: vertical;
  }
  .nm-tentacle__spawn-form input:focus,
  .nm-tentacle__spawn-form textarea:focus {
    outline: none;
    border-color: #4f46e5;
  }
  .nm-tentacle__terminal {
    min-height: 0;
    padding: 0.5rem;
  }
  .nm-tentacle__terminal .xterm { height: 100%; }
  .nm-tentacle__inbox {
    display: flex;
    flex-direction: column;
    min-height: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.75rem 0.75rem 0.5rem;
    gap: 0.5rem;
  }
  .nm-tentacle__inbox-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nm-tentacle__inbox-header h2 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
  .nm-tentacle__inbox-status {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
  }
  .nm-tentacle__inbox-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .nm-tentacle__inbox-item {
    padding: 0.4rem 0.5rem;
    border-radius: 0.3rem;
    background: rgba(255, 255, 255, 0.04);
    font-size: 0.75rem;
    line-height: 1.35;
  }
  .nm-tentacle__inbox-item--pending {
    background: rgba(79, 70, 229, 0.15);
    border-left: 2px solid #818cf8;
    padding-left: calc(0.5rem - 2px);
  }
  .nm-tentacle__inbox-from {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.2rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .nm-tentacle__inbox-content {
    color: #e5e5e5;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .nm-tentacle__inbox-empty {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
    padding: 0.5rem 0;
    text-align: center;
  }
</style>
