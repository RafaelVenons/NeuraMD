<% content_for :title, "Tentáculo — #{@note.title} — NeuraMD" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "xterm", "data-turbo-track": "reload" %>
<% end %>

<div class="nm-tentacle"
     data-controller="tentacle"
     data-tentacle-tentacle-id-value="<%= @tentacle_id %>"
     data-tentacle-start-url-value="<%= note_tentacle_path(@note.slug, format: :json) %>"
     data-tentacle-stop-url-value="<%= note_tentacle_path(@note.slug, format: :json) %>"
     data-tentacle-csrf-value="<%= form_authenticity_token %>"
     data-tentacle-alive-value="<%= @session&.alive? || false %>">

  <header class="nm-tentacle__header">
    <div class="nm-tentacle__title">
      <h1><%= @note.title %></h1>
      <p class="nm-tentacle__meta">
        Worktree: <code><%= @worktree %></code>
        · <%= link_to "↗ Dashboard", tentacles_dashboard_path, class: "nm-tentacle__meta-link" %>
      </p>
    </div>
    <div class="nm-tentacle__actions">
      <label class="nm-tentacle__command">
        Comando
        <select data-tentacle-target="command">
          <option value="bash">bash</option>
          <option value="claude" selected>claude</option>
        </select>
      </label>
      <button type="button"
              class="nm-tentacle__btn nm-tentacle__btn--primary"
              data-tentacle-target="startButton"
              data-action="tentacle#start">
        Iniciar
      </button>
      <button type="button"
              class="nm-tentacle__btn"
              data-tentacle-target="stopButton"
              data-action="tentacle#stop"
              hidden>
        Encerrar
      </button>
      <span class="nm-tentacle__status" data-tentacle-target="status">idle</span>
    </div>
  </header>

  <div class="nm-tentacle__body">
    <aside class="nm-tentacle__todos"
           data-controller="tentacle-todos"
           data-tentacle-todos-url-value="<%= todos_note_tentacle_path(@note.slug, format: :json) %>"
           data-tentacle-todos-csrf-value="<%= form_authenticity_token %>">
      <header class="nm-tentacle__todos-header">
        <h2>Todos</h2>
        <span class="nm-tentacle__todos-status" data-tentacle-todos-target="status">—</span>
      </header>
      <ul class="nm-tentacle__todos-list" data-tentacle-todos-target="list"></ul>
      <form class="nm-tentacle__todos-form"
            data-action="submit->tentacle-todos#add">
        <input type="text"
               placeholder="Nova task…"
               data-tentacle-todos-target="input"
               autocomplete="off">
        <button type="submit" class="nm-tentacle__btn">Adicionar</button>
      </form>
    </aside>

    <div class="nm-tentacle__terminal" data-tentacle-target="terminal"></div>
  </div>
</div>

<style>
  .nm-tentacle {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    background: #0b0b0b;
    color: #d4d4d4;
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .nm-tentacle__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    gap: 1rem;
  }
  .nm-tentacle__title h1 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }
  .nm-tentacle__meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.25rem 0 0;
  }
  .nm-tentacle__meta-link {
    color: #a5b4fc;
    text-decoration: none;
  }
  .nm-tentacle__meta-link:hover { text-decoration: underline; }
  .nm-tentacle__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .nm-tentacle__command {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }
  .nm-tentacle__command select {
    background: #1a1a1a;
    color: #e5e5e5;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
  }
  .nm-tentacle__btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #e5e5e5;
    padding: 0.35rem 0.85rem;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .nm-tentacle__btn--primary {
    background: #4f46e5;
    border-color: #4f46e5;
  }
  .nm-tentacle__btn:hover { opacity: 0.85; }
  .nm-tentacle__status {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.7);
  }
  .nm-tentacle__body {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: 260px 1fr;
  }
  .nm-tentacle__todos {
    display: flex;
    flex-direction: column;
    min-height: 0;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.75rem 0.75rem 0.5rem;
    gap: 0.5rem;
  }
  .nm-tentacle__todos-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nm-tentacle__todos-header h2 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }
  .nm-tentacle__todos-status {
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
  }
  .nm-tentacle__todos-list {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .nm-tentacle__todo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.35rem;
    border-radius: 0.25rem;
    font-size: 0.8rem;
    color: #e5e5e5;
  }
  .nm-tentacle__todo:hover { background: rgba(255, 255, 255, 0.04); }
  .nm-tentacle__todo input[type="checkbox"] { accent-color: #4f46e5; flex-shrink: 0; }
  .nm-tentacle__todo--done .nm-tentacle__todo-text {
    text-decoration: line-through;
    color: rgba(255, 255, 255, 0.45);
  }
  .nm-tentacle__todo-text {
    flex: 1;
    min-width: 0;
    word-break: break-word;
  }
  .nm-tentacle__todo-remove {
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0 0.2rem;
  }
  .nm-tentacle__todo-remove:hover { color: #f87171; }
  .nm-tentacle__todos-form {
    display: flex;
    gap: 0.25rem;
  }
  .nm-tentacle__todos-form input {
    flex: 1;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #e5e5e5;
    border-radius: 0.25rem;
    padding: 0.3rem 0.5rem;
    font-size: 0.8rem;
  }
  .nm-tentacle__todos-form input:focus {
    outline: none;
    border-color: #4f46e5;
  }
  .nm-tentacle__terminal {
    min-height: 0;
    padding: 0.5rem;
  }
  .nm-tentacle__terminal .xterm { height: 100%; }
</style>
