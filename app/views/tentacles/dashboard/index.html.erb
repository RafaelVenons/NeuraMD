<% content_for :title, "Tentáculos — NeuraMD" %>

<div class="nm-tentacles-dashboard">
  <header class="nm-tentacles-dashboard__header">
    <h1>Tentáculos</h1>
    <p class="nm-tentacles-dashboard__meta">
      <%= pluralize(@sessions.size, "sessão ativa", plural: "sessões ativas") %>
    </p>
  </header>

  <% if @sessions.empty? %>
    <div class="nm-tentacles-dashboard__empty">
      Nenhum tentáculo rodando. Abra uma nota e inicie um tentáculo em
      <code>/notes/:slug/tentacle</code>.
    </div>
  <% else %>
    <form class="nm-tentacles-dashboard__form" action="<%= tentacles_multi_path %>" method="get">
      <ul class="nm-tentacles-dashboard__list">
        <% @sessions.each do |row| %>
          <li class="nm-tentacles-dashboard__row">
            <label class="nm-tentacles-dashboard__check">
              <input type="checkbox" name="ids[]" value="<%= row[:tentacle_id] %>">
              <span class="nm-tentacles-dashboard__title">
                <%= row[:note].title %>
              </span>
            </label>
            <span class="nm-tentacles-dashboard__cmd"><code><%= Array(row[:command]).join(" ") %></code></span>
            <span class="nm-tentacles-dashboard__pill <%= row[:alive] ? "is-alive" : "is-stale" %>">
              <%= row[:alive] ? "alive" : "stale" %>
            </span>
            <span class="nm-tentacles-dashboard__since">
              <%= time_ago_in_words(row[:started_at]) %> atrás
            </span>
            <%= link_to "Abrir", note_tentacle_path(row[:note].slug),
                        class: "nm-tentacles-dashboard__open" %>
          </li>
        <% end %>
      </ul>
      <div class="nm-tentacles-dashboard__actions">
        <button type="submit" class="nm-tentacles-dashboard__btn">Abrir selecionados em multi</button>
      </div>
    </form>
  <% end %>
</div>

<style>
  .nm-tentacles-dashboard {
    max-width: 960px;
    margin: 2rem auto;
    padding: 0 1rem;
    color: #e5e5e5;
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .nm-tentacles-dashboard__header h1 {
    font-size: 1.25rem;
    margin: 0;
  }
  .nm-tentacles-dashboard__meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0.25rem 0 1.25rem;
  }
  .nm-tentacles-dashboard__empty {
    padding: 1rem;
    border: 1px dashed rgba(255, 255, 255, 0.15);
    border-radius: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.85rem;
  }
  .nm-tentacles-dashboard__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .nm-tentacles-dashboard__row {
    display: grid;
    grid-template-columns: 1fr auto auto auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.375rem;
    background: #101010;
    font-size: 0.8rem;
  }
  .nm-tentacles-dashboard__check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }
  .nm-tentacles-dashboard__check input { accent-color: #4f46e5; }
  .nm-tentacles-dashboard__title { font-weight: 600; }
  .nm-tentacles-dashboard__cmd { color: rgba(255, 255, 255, 0.6); }
  .nm-tentacles-dashboard__pill {
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .nm-tentacles-dashboard__pill.is-alive {
    background: rgba(34, 197, 94, 0.15);
    color: #86efac;
  }
  .nm-tentacles-dashboard__pill.is-stale {
    background: rgba(248, 113, 113, 0.12);
    color: #fca5a5;
  }
  .nm-tentacles-dashboard__since {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.45);
  }
  .nm-tentacles-dashboard__open {
    color: #a5b4fc;
    text-decoration: none;
    font-size: 0.75rem;
  }
  .nm-tentacles-dashboard__open:hover { text-decoration: underline; }
  .nm-tentacles-dashboard__actions {
    margin-top: 1rem;
    display: flex;
    justify-content: flex-end;
  }
  .nm-tentacles-dashboard__btn {
    background: #4f46e5;
    color: #fff;
    border: 0;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    cursor: pointer;
    font-size: 0.8rem;
  }
  .nm-tentacles-dashboard__btn:hover { opacity: 0.9; }
</style>
