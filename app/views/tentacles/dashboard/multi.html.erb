<% content_for :title, "Multi tentáculo — NeuraMD" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "xterm", "data-turbo-track": "reload" %>
<% end %>

<div class="nm-tentacle-multi" style="--nm-panel-count: <%= @panels.size %>;">
  <header class="nm-tentacle-multi__header">
    <h1>Multi — <%= pluralize(@panels.size, "painel", plural: "painéis") %></h1>
    <%= link_to "← Dashboard", tentacles_dashboard_path, class: "nm-tentacle-multi__back" %>
  </header>

  <div class="nm-tentacle-multi__grid">
    <% @panels.each do |panel| %>
      <article class="nm-tentacle-multi__panel"
               data-controller="tentacle"
               data-tentacle-tentacle-id-value="<%= panel[:tentacle_id] %>"
               data-tentacle-start-url-value="<%= note_tentacle_path(panel[:note].slug, format: :json) %>"
               data-tentacle-stop-url-value="<%= note_tentacle_path(panel[:note].slug, format: :json) %>"
               data-tentacle-csrf-value="<%= form_authenticity_token %>"
               data-tentacle-alive-value="<%= panel[:alive] %>">
        <header class="nm-tentacle-multi__panel-header">
          <h2><%= link_to panel[:note].title, note_tentacle_path(panel[:note].slug) %></h2>
          <div class="nm-tentacle-multi__panel-actions">
            <label class="nm-tentacle-multi__cmd">
              <select data-tentacle-target="command">
                <option value="bash">bash</option>
                <option value="claude" selected>claude</option>
              </select>
            </label>
            <button type="button"
                    class="nm-tentacle-multi__btn nm-tentacle-multi__btn--primary"
                    data-tentacle-target="startButton"
                    data-action="tentacle#start"
                    <%= "hidden" if panel[:alive] %>>
              Iniciar
            </button>
            <button type="button"
                    class="nm-tentacle-multi__btn"
                    data-tentacle-target="stopButton"
                    data-action="tentacle#stop"
                    <%= "hidden" unless panel[:alive] %>>
              Encerrar
            </button>
            <span class="nm-tentacle-multi__status"
                  data-tentacle-target="status"><%= panel[:alive] ? "running" : "idle" %></span>
          </div>
        </header>
        <div class="nm-tentacle-multi__terminal" data-tentacle-target="terminal"></div>
      </article>
    <% end %>
  </div>
</div>

<style>
  .nm-tentacle-multi {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    background: #0b0b0b;
    color: #d4d4d4;
    font-family: "JetBrains Mono", ui-monospace, monospace;
  }
  .nm-tentacle-multi__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .nm-tentacle-multi__header h1 {
    font-size: 0.9rem;
    margin: 0;
    font-weight: 600;
  }
  .nm-tentacle-multi__back {
    color: #a5b4fc;
    text-decoration: none;
    font-size: 0.75rem;
  }
  .nm-tentacle-multi__back:hover { text-decoration: underline; }
  .nm-tentacle-multi__grid {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: repeat(var(--nm-panel-count), minmax(0, 1fr));
    gap: 1px;
    background: rgba(255, 255, 255, 0.08);
  }
  .nm-tentacle-multi__panel {
    display: flex;
    flex-direction: column;
    min-height: 0;
    background: #0b0b0b;
  }
  .nm-tentacle-multi__panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0.6rem;
    gap: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.75rem;
  }
  .nm-tentacle-multi__panel-header h2 {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .nm-tentacle-multi__panel-header a {
    color: #e5e5e5;
    text-decoration: none;
  }
  .nm-tentacle-multi__panel-header a:hover { color: #a5b4fc; }
  .nm-tentacle-multi__panel-actions {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .nm-tentacle-multi__cmd select {
    background: #1a1a1a;
    color: #e5e5e5;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.25rem;
    padding: 0.15rem 0.35rem;
    font-size: 0.7rem;
  }
  .nm-tentacle-multi__btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #e5e5e5;
    padding: 0.2rem 0.55rem;
    border-radius: 0.25rem;
    font-size: 0.7rem;
    cursor: pointer;
  }
  .nm-tentacle-multi__btn--primary {
    background: #4f46e5;
    border-color: #4f46e5;
  }
  .nm-tentacle-multi__btn:hover { opacity: 0.85; }
  .nm-tentacle-multi__status {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.65);
  }
  .nm-tentacle-multi__terminal {
    flex: 1;
    min-height: 0;
    padding: 0.4rem;
  }
  .nm-tentacle-multi__terminal .xterm { height: 100%; }
</style>
