<% content_for :title, "Editar #{@note.title} — NeuraMD" %>

<div class="mx-auto max-w-lg">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Editar Nota</h1>
    <%= link_to "← Cancelar", note_path(@note.slug), class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <%= render "form", note: @note %>

  <div class="mt-6 pt-6 border-t border-gray-200">
    <%= button_to "Arquivar nota", note_path(@note.slug),
        method: :delete,
        class: "text-sm text-red-600 hover:underline bg-transparent border-0 cursor-pointer p-0",
        data: {turbo_confirm: "Tem certeza? A nota será arquivada."} %>
  </div>
</div>
