<%= form_with model: note, class: "space-y-5" do |f| %>
  <% if note.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
        <% note.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Título", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
        class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500",
        placeholder: "Título da nota",
        autofocus: true %>
  </div>

  <div>
    <%= f.label :detected_language, "Idioma", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :detected_language,
        Note::SUPPORTED_LANGUAGES.map { |l| [l, l] },
        {include_blank: "Detectar automaticamente"},
        class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
  </div>

  <div class="pt-2">
    <%= f.submit note.new_record? ? "Criar Nota" : "Salvar",
        class: "w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 cursor-pointer" %>
  </div>
<% end %>
