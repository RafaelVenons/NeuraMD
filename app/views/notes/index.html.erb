<% content_for :title, "Notas — NeuraMD" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Notas</h1>
  <%= link_to "Nova Nota", new_note_path,
      class: "inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
</div>

<%= form_with url: notes_path, method: :get, local: true, class: "mb-6 rounded-xl border border-gray-200 bg-white p-4 shadow-sm" do |form| %>
  <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
    <div class="flex-1">
      <%= form.search_field :q,
          value: @search_query,
          placeholder: "Buscar por titulo ou conteudo...",
          class: "w-full rounded-lg border border-gray-200 px-4 py-2.5 text-sm text-gray-900 outline-none focus:border-blue-500" %>
    </div>
    <label class="inline-flex items-center gap-2 text-sm text-gray-600">
      <%= form.check_box :regex, { checked: @search_regex }, "1", "0" %>
      Regex
    </label>
    <div class="flex items-center gap-2">
      <%= form.submit "Buscar",
          class: "inline-flex items-center justify-center rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-700" %>
      <% if @search_query.present? || @search_regex %>
        <%= link_to "Limpar", notes_path, class: "text-sm font-medium text-gray-500 hover:text-gray-900" %>
      <% end %>
    </div>
  </div>
  <p class="mt-2 text-xs text-gray-500">Use <code>Ctrl+Shift+K</code> para abrir o finder rapido em qualquer tela.</p>
<% end %>

<% if @search_error.present? %>
  <div class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
    <%= @search_error %>
  </div>
<% end %>

<% if @notes.empty? %>
  <div class="rounded-lg border-2 border-dashed border-gray-200 py-16 text-center">
    <% if @search_query.present? || @search_regex %>
      <p class="text-gray-500 mb-2">Nenhuma nota encontrada para esta busca.</p>
      <%= link_to "Voltar para todas as notas", notes_path,
          class: "text-blue-600 hover:underline font-medium" %>
    <% else %>
      <p class="text-gray-500 mb-4">Nenhuma nota ainda.</p>
      <%= link_to "Criar primeira nota", new_note_path,
          class: "text-blue-600 hover:underline font-medium" %>
    <% end %>
  </div>
<% else %>
  <div class="space-y-2">
    <% @notes.each do |note| %>
      <%= link_to note_path(note.slug),
          class: "block rounded-lg border border-gray-200 bg-white px-5 py-4 hover:border-blue-300 hover:shadow-sm transition-all group" do %>
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <h2 class="font-semibold text-gray-900 group-hover:text-blue-700 truncate">
              <%= note.title %>
            </h2>
            <% if note.head_revision&.content_plain.present? %>
              <p class="mt-1 text-sm text-gray-500 line-clamp-2">
                <%= note.head_revision.content_plain.truncate(160) %>
              </p>
            <% end %>
          </div>
          <div class="flex-shrink-0 text-right">
            <% if note.detected_language.present? %>
              <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500 font-mono mb-1">
                <%= note.detected_language %>
              </span>
            <% end %>
            <p class="text-xs text-gray-400"><%= note.updated_at.strftime("%d/%m/%Y %H:%M") %></p>
          </div>
        </div>
        <% if note.tags.any? %>
          <div class="mt-2 flex flex-wrap gap-1">
            <% note.tags.each do |tag| %>
              <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium"
                    style="background-color: <%= tag.color_hex || '#e5e7eb' %>22; color: <%= tag.color_hex || '#6b7280' %>">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <% if @search_query.present? || @search_regex %>
    <div class="mt-6 flex items-center justify-between text-sm text-gray-500">
      <span>Pagina <%= @search_page %></span>
      <div class="flex items-center gap-3">
        <% if @search_page > 1 %>
          <%= link_to "Anterior", notes_path(q: @search_query, regex: @search_regex ? "1" : "0", page: @search_page - 1),
              class: "font-medium text-blue-600 hover:underline" %>
        <% end %>
        <% if @has_more_results %>
          <%= link_to "Proxima", notes_path(q: @search_query, regex: @search_regex ? "1" : "0", page: @search_page + 1),
              class: "font-medium text-blue-600 hover:underline" %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
