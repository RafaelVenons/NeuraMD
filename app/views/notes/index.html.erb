<% content_for :title, "Notas — NeuraMD" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Notas</h1>
  <%= link_to "Nova Nota", new_note_path,
      class: "inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
</div>

<% if @notes.empty? %>
  <div class="rounded-lg border-2 border-dashed border-gray-200 py-16 text-center">
    <p class="text-gray-500 mb-4">Nenhuma nota ainda.</p>
    <%= link_to "Criar primeira nota", new_note_path,
        class: "text-blue-600 hover:underline font-medium" %>
  </div>
<% else %>
  <div class="space-y-2">
    <% @notes.each do |note| %>
      <%= link_to note_path(note.slug),
          class: "block rounded-lg border border-gray-200 bg-white px-5 py-4 hover:border-blue-300 hover:shadow-sm transition-all group" do %>
        <div class="flex items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <h2 class="font-semibold text-gray-900 group-hover:text-blue-700 truncate">
              <%= note.title %>
            </h2>
            <% if note.head_revision&.content_plain.present? %>
              <p class="mt-1 text-sm text-gray-500 line-clamp-2">
                <%= note.head_revision.content_plain.truncate(160) %>
              </p>
            <% end %>
          </div>
          <div class="flex-shrink-0 text-right">
            <% if note.detected_language.present? %>
              <span class="inline-block rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500 font-mono mb-1">
                <%= note.detected_language %>
              </span>
            <% end %>
            <p class="text-xs text-gray-400"><%= note.updated_at.strftime("%d/%m/%Y %H:%M") %></p>
          </div>
        </div>
        <% if note.tags.any? %>
          <div class="mt-2 flex flex-wrap gap-1">
            <% note.tags.each do |tag| %>
              <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium"
                    style="background-color: <%= tag.color_hex || '#e5e7eb' %>22; color: <%= tag.color_hex || '#6b7280' %>">
                <%= tag.name %>
              </span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
