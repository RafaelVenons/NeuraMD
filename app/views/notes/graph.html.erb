<% content_for :title, "Grafo — NeuraMD" %>

<section class="graph-shell"
         data-controller="graph-view"
         data-graph-view-data-url-value="<%= api_graph_path %>">
  <div class="graph-header">
    <div>
      <p class="graph-header__eyebrow">Mapa semântico</p>
      <h1 class="graph-header__title">Grafo das notas</h1>
      <p class="graph-header__subtitle">
        Navegue pelas relações entre notas, filtre por tags e reduza o grafo por profundidade.
      </p>
    </div>
    <div class="graph-header__meta" data-graph-view-target="meta">Carregando grafo...</div>
  </div>

  <div class="graph-layout">
    <aside class="graph-sidebar">
      <div class="graph-panel">
        <label class="graph-field">
          <span>Buscar nota</span>
          <input type="search"
                 placeholder="Titulo..."
                 data-graph-view-target="nodeFilter"
                 data-action="input->graph-view#applyFilters">
        </label>

        <label class="graph-field">
          <span>Nota central</span>
          <select data-graph-view-target="focusFilter"
                  data-action="change->graph-view#applyFilters">
            <option value="">Sem foco</option>
          </select>
        </label>

        <label class="graph-field">
          <span>Tag</span>
          <select data-graph-view-target="tagFilter"
                  data-action="change->graph-view#applyFilters">
            <option value="">Todas as tags</option>
          </select>
        </label>

        <label class="graph-field">
          <span>Profundidade</span>
          <select data-graph-view-target="depthFilter"
                  data-action="change->graph-view#applyFilters">
            <option value="all">Tudo</option>
            <option value="1">1 salto</option>
            <option value="2" selected>2 saltos</option>
            <option value="3">3 saltos</option>
          </select>
        </label>
      </div>

      <div class="graph-panel">
        <p class="graph-panel__title">Relações</p>
        <label class="graph-check">
          <input type="checkbox" checked data-graph-view-target="roleParent" data-action="change->graph-view#applyFilters">
          <span>Father</span>
        </label>
        <label class="graph-check">
          <input type="checkbox" checked data-graph-view-target="roleChild" data-action="change->graph-view#applyFilters">
          <span>Child</span>
        </label>
        <label class="graph-check">
          <input type="checkbox" checked data-graph-view-target="roleSibling" data-action="change->graph-view#applyFilters">
          <span>Brother</span>
        </label>
      </div>

      <div class="graph-panel">
        <p class="graph-panel__title">Legenda</p>
        <div class="graph-legend" data-graph-view-target="legend"></div>
      </div>
    </aside>

    <div class="graph-stage">
      <div class="graph-stage__frame"
           data-graph-view-target="canvas"
           data-action="click->graph-view#openNode"></div>
      <p class="graph-stage__empty hidden" data-graph-view-target="empty">
        Nenhuma nota ficou visível com os filtros atuais.
      </p>
      <p class="graph-stage__error hidden" data-graph-view-target="error"></p>
    </div>
  </div>
</section>
