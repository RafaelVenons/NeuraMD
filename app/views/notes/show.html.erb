<% content_for :title, "#{@note.title} — NeuraMD" %>

<div id="editor-root"
     class="flex flex-col"
     style="height: 100dvh; background: var(--theme-bg-primary);"
     data-controller="note-shell editor autosave ai-review tts note-tags"
     data-note-shell-target="root"
     data-editor-autosave-url-value="<%= draft_note_path(@note.slug) %>"
     data-editor-revisions-url-value="<%= revisions_note_path(@note.slug) %>"
     data-editor-slug-value="<%= @note.slug %>"
     data-editor-title-value="<%= @note.title %>"
     data-editor-language-value="<%= @note.detected_language %>"
     data-editor-focus-title-value="<%= params[:focus] == 'title' %>"
     data-editor-initial-revision-id-value="<%= @revision&.id %>"
     data-editor-initial-revision-kind-value="<%= @revision&.revision_kind %>"
     data-editor-head-revision-id-value="<%= @note.head_revision_id %>"
     data-ai-review-queue-url-value="<%= ai_requests_dashboard_path(format: :json) %>"
     data-ai-review-queue-reorder-url-value="<%= reorder_ai_requests_dashboard_path %>"
     data-ai-review-queue-request-url-template-value="<%= ai_request_payload_path("__REQUEST_ID__") %>"
     data-ai-review-queue-retry-url-template-value="<%= retry_ai_request_path("__REQUEST_ID__") %>"
     data-ai-review-queue-cancel-url-template-value="<%= ai_request_dashboard_path("__REQUEST_ID__") %>"
     data-ai-review-queue-resolve-url-template-value="<%= resolve_ai_request_queue_path("__REQUEST_ID__") %>"
     data-ai-review-status-url-value="<%= ai_status_note_path(@note.slug) %>"
     data-ai-review-review-url-value="<%= ai_review_note_path(@note.slug) %>"
     data-ai-review-history-url-value="<%= ai_requests_note_path(@note.slug) %>"
     data-ai-review-reorder-url-value="<%= reorder_ai_requests_note_path(@note.slug) %>"
     data-ai-review-request-url-template-value="<%= ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-retry-url-template-value="<%= retry_ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-cancel-url-template-value="<%= ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-resolve-url-template-value="<%= resolve_ai_request_queue_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-create-translated-note-url-template-value="<%= ai_request_translated_note_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-note-title-value="<%= @note.title %>"
     data-ai-review-note-language-value="<%= @note.detected_language %>"
     data-ai-review-language-options-value="<%= Note::SUPPORTED_LANGUAGES.reject { |lang| lang == @note.detected_language }.to_json %>"
     data-ai-review-language-labels-value="<%= Notes::TranslationNoteService::LANGUAGE_LABELS.to_json %>"
     data-autosave-draft-url-value="<%= draft_note_path(@note.slug) %>"
     data-autosave-checkpoint-url-value="<%= checkpoint_note_path(@note.slug) %>"
     data-autosave-local-key-value="note-draft-<%= @note.id %>"
     data-autosave-server-updated-at-value="<%= @revision&.updated_at&.iso8601 %>"
     data-autosave-draft-ms-value="60000"
     data-autosave-local-ms-value="3000"
     data-tts-status-url-value="<%= tts_status_note_path(@note.slug) %>"
     data-tts-generate-url-value="<%= tts_generate_note_path(@note.slug) %>"
     data-tts-show-url-value="<%= tts_show_note_path(@note.slug) %>"
     data-tts-reject-url-value="<%= tts_reject_note_path(@note.slug) %>"
     data-tts-audio-url-value="<%= tts_audio_note_path(@note.slug) %>"
     data-tts-library-url-value="<%= tts_library_note_path(@note.slug) %>"
     data-tts-note-language-value="<%= @note.detected_language || 'pt-BR' %>"
     data-note-tags-note-id-value="<%= @note.id %>"
     data-note-tags-initial-tags-value="<%= @note.tags.where(tag_scope: %w[note both]).select(:id, :name, :color_hex).map { |t| { id: t.id, name: t.name, color_hex: t.color_hex } }.to_json %>">

  <div data-note-shell-target="streamSource">
    <%= render "notes/ai_requests_stream", note: @note %>
  </div>

  <%# ── Toolbar ─────────────────────────────────────────── %>
  <div id="editor-toolbar"
       class="flex items-center gap-2 border-b border-gray-800 bg-gray-900 px-3 py-2 flex-shrink-0">

    <%# Back link %>
    <%= link_to graph_path,
        class: "flex-shrink-0 rounded p-1.5 text-gray-400 hover:bg-gray-800 hover:text-gray-200",
        title: "Voltar para o grafo",
        data: { turbo_prefetch: false, action: "click->page-transition#navigate", transition_kind: "note-to-graph" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
    <% end %>

    <%# Editable title %>
    <input type="text"
           value="<%= @note.title %>"
           class="flex-1 min-w-0 bg-transparent text-sm font-medium text-gray-200 placeholder-gray-500 outline-none border-b border-transparent focus:border-gray-600 py-0.5"
           data-editor-target="titleInput"
           placeholder="Título da nota">

    <%# Language badge — only show when language is detected %>
    <% if @note.detected_language.present? %>
      <span class="flex-shrink-0 rounded bg-gray-800 px-2 py-0.5 text-xs font-mono text-gray-400"
            data-editor-target="langBadge">
        <%= @note.detected_language %>
      </span>
    <% else %>
      <span class="hidden flex-shrink-0 rounded bg-gray-800 px-2 py-0.5 text-xs font-mono text-gray-400"
            data-editor-target="langBadge"></span>
    <% end %>

    <%# Note tags — compact dropdown %>
    <div class="relative flex-shrink-0">
      <button type="button"
              title="Tags da nota"
              class="toolbar-btn flex items-center gap-1"
              data-note-tags-target="toggleButton"
              data-action="click->note-tags#toggleDropdown">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/>
          <line x1="7" y1="7" x2="7.01" y2="7"/>
        </svg>
        <span class="text-xs" data-note-tags-target="badge"></span>
      </button>
      <div class="hidden absolute left-0 top-full z-40 mt-1 w-56 max-h-72 overflow-y-auto rounded-lg border shadow-xl"
           style="border-color: var(--toolbar-border); background: var(--theme-bg-secondary);"
           data-note-tags-target="dropdown">
      </div>
    </div>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Format buttons — inline %>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <button title="Negrito (Ctrl+B)"
              class="toolbar-btn"
              data-action="click->text-format#bold">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 12h8a4 4 0 000-8H6v8zm0 0h9a4 4 0 010 8H6v-8z"/>
        </svg>
      </button>
      <button title="Itálico (Ctrl+I)"
              class="toolbar-btn"
              data-action="click->text-format#italic">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/>
          <line x1="15" y1="4" x2="9" y2="20"/>
        </svg>
      </button>
      <button title="Tachado (Ctrl+Shift+S)"
              class="toolbar-btn"
              data-action="click->text-format#strikethrough">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M16 4H9a3 3 0 00-1 5.83"/><path d="M8 20h7a3 3 0 001-5.83"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
        </svg>
      </button>
      <button title="Destaque (Ctrl+Shift+H)"
              class="toolbar-btn"
              data-action="click->text-format#highlight">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
      </button>
      <button title="Código inline (Ctrl+`)"
              class="toolbar-btn"
              data-action="click->text-format#inlineCode">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
      </button>
      <button title="Link (Ctrl+K)"
              class="toolbar-btn"
              data-action="click->text-format#link">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
        </svg>
      </button>
    </div>

    <%# Format buttons — block %>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <button title="Título H1"
              class="toolbar-btn text-[10px] font-bold leading-none"
              data-action="click->text-format#heading1">
        H1
      </button>
      <button title="Título H2"
              class="toolbar-btn text-[10px] font-bold leading-none"
              data-action="click->text-format#heading2">
        H2
      </button>
      <button title="Título H3"
              class="toolbar-btn text-[10px] font-bold leading-none"
              data-action="click->text-format#heading3">
        H3
      </button>
      <button title="Lista com marcadores"
              class="toolbar-btn"
              data-action="click->text-format#bulletList">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/>
          <circle cx="5" cy="6" r="1" fill="currentColor"/><circle cx="5" cy="12" r="1" fill="currentColor"/><circle cx="5" cy="18" r="1" fill="currentColor"/>
        </svg>
      </button>
      <button title="Lista numerada"
              class="toolbar-btn"
              data-action="click->text-format#numberList">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="10" y1="6" x2="20" y2="6"/><line x1="10" y1="12" x2="20" y2="12"/><line x1="10" y1="18" x2="20" y2="18"/>
          <text x="3" y="8" font-size="7" fill="currentColor" stroke="none" font-family="monospace">1</text>
          <text x="3" y="14" font-size="7" fill="currentColor" stroke="none" font-family="monospace">2</text>
          <text x="3" y="20" font-size="7" fill="currentColor" stroke="none" font-family="monospace">3</text>
        </svg>
      </button>
      <button title="Citação"
              class="toolbar-btn"
              data-action="click->text-format#blockquote">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21z"/>
          <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3z"/>
        </svg>
      </button>
      <button title="Bloco de código"
              class="toolbar-btn"
              data-action="click->text-format#codeBlock">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <polyline points="9 8 5 12 9 16"/><polyline points="15 8 19 12 15 16"/>
        </svg>
      </button>
      <button title="Inserir tabela"
              class="toolbar-btn"
              data-action="click->table-editor#open">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/>
          <line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/>
        </svg>
      </button>
      <button title="Inserir emoji"
              class="toolbar-btn"
              data-action="click->emoji-picker#open">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
          <line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
        </svg>
      </button>
    </div>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Preview toggle %>
    <button title="Buscar notas (Ctrl+Shift+K)"
            class="toolbar-btn"
            data-action="click->note-finder#open">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
    </button>

    <button title="Toggle Preview (Ctrl+P)"
            class="toolbar-btn"
            data-action="click->editor#togglePreview"
            data-editor-target="previewToggleBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    </button>

    <button title="Propriedades (Ctrl+Shift+P)"
            class="toolbar-btn"
            data-action="click->editor#toggleProperties"
            data-editor-target="propertiesToggleBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
      </svg>
    </button>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <button title="Melhorar Markdown com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openRewrite">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 20h4l10.5-10.5a2.1 2.1 0 0 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
      </svg>
    </button>

    <button title="Revisar gramática com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openGrammar">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5V5a2 2 0 0 1 2-2h8l6 6v10.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/>
        <path d="M14 3v6h6"/>
        <path d="M8 13h8M8 17h5"/>
      </svg>
    </button>

    <button title="Traduzir com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openTranslate">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 8h14"/>
        <path d="M9 5v3c0 4-2 7-5 9"/>
        <path d="M15 11l4 8"/>
        <path d="M13 19l4-8 4 8"/>
      </svg>
    </button>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# TTS generate button + dropdown %>
    <div class="relative flex-shrink-0" data-tts-target="dropdownWrapper">
      <button title="Gerar Audio (TTS)"
              class="toolbar-btn"
              data-tts-target="generateBtn"
              data-action="click->tts#openDialog">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M11 5L6 9H2v6h4l5 4V5z"/>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
        </svg>
      </button>

      <%# TTS Dialog (dropdown) %>
      <div data-tts-target="dialog"
           class="hidden absolute right-0 top-full mt-1 w-96 z-50 rounded-xl border shadow-2xl"
           style="background: var(--theme-bg-secondary); border-color: var(--toolbar-border);">

        <%# ── Tab bar ── %>
        <div class="flex border-b" style="border-color: var(--toolbar-border);">
          <button data-tts-target="generateTab"
                  data-action="click->tts#switchToGenerate"
                  class="flex-1 px-4 py-2.5 text-xs font-semibold border-b-2 border-[var(--theme-accent)]"
                  style="color: var(--theme-text-primary);">
            Gerar
          </button>
          <button data-tts-target="libraryTab"
                  data-action="click->tts#switchToLibrary"
                  class="flex-1 px-4 py-2.5 text-xs font-semibold border-b-2 border-transparent"
                  style="color: var(--theme-text-muted);">
            Biblioteca
          </button>
          <button class="px-3 py-2.5 text-xs"
                  style="color: var(--theme-text-muted);"
                  data-action="click->tts#closeDialog"
                  title="Fechar">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>

        <%# ── Generate panel ── %>
        <div data-tts-target="generatePanel" class="p-4">
          <label class="block text-xs mb-1" style="color: var(--theme-text-muted);">Idioma</label>
          <select data-tts-target="languageSelect"
                  data-action="change->tts#languageChanged"
                  class="tts-select mb-2">
            <option value="pt-BR">Portugues (BR)</option>
            <option value="en-US">English (US)</option>
            <option value="en-GB">English (GB)</option>
            <option value="zh-CN">Chinese (Mandarin)</option>
            <option value="ja-JP">Japanese</option>
            <option value="ko-KR">Korean</option>
            <option value="es-ES">Spanish</option>
            <option value="fr-FR">French</option>
            <option value="it-IT">Italian</option>
            <option value="hi-IN">Hindi</option>
          </select>

          <label class="block text-xs mb-1" style="color: var(--theme-text-muted);">Provider</label>
          <select data-tts-target="providerSelect"
                  data-action="change->tts#providerChanged"
                  class="tts-select mb-2">
          </select>

          <label class="block text-xs mb-1" style="color: var(--theme-text-muted);">Voz</label>
          <select data-tts-target="voiceSelect" class="tts-select mb-2"></select>

          <label class="block text-xs mb-1" style="color: var(--theme-text-muted);">Formato</label>
          <select data-tts-target="formatSelect" class="tts-select mb-3">
            <option value="mp3">MP3</option>
            <option value="wav">WAV</option>
            <option value="opus">Opus</option>
          </select>

          <div class="flex gap-2">
            <button class="tts-btn-primary flex-1"
                    data-action="click->tts#generate">
              Gerar
            </button>
            <button class="tts-btn-secondary"
                    data-action="click->tts#closeDialog">
              Cancelar
            </button>
          </div>
        </div>

        <%# ── Library panel ── %>
        <div data-tts-target="libraryPanel" class="hidden p-4">
          <div data-tts-target="libraryList"
               class="max-h-80 overflow-y-auto space-y-2">
            <p class="text-xs text-center py-4" style="color: var(--theme-text-muted);">Carregando...</p>
          </div>
        </div>
      </div>
    </div>

    <%# TTS spinner (hidden by default) %>
    <span data-tts-target="spinner" class="hidden toolbar-btn animate-pulse text-xs" style="color: var(--theme-text-faint)">
      <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
        <path d="M12 2a10 10 0 0 1 10 10" stroke-opacity="0.75"/>
      </svg>
    </span>

    <%# TTS status label %>
    <span data-tts-target="statusLabel" class="text-xs flex-shrink-0" style="color: var(--theme-text-faint)"></span>

    <%# Stale audio notice — shown when note is edited after TTS was generated %>
    <button data-tts-target="staleNotice"
            data-action="click->tts#loadStaleAudio"
            class="hidden text-xs px-2 py-0.5 rounded-full cursor-pointer flex items-center gap-1 hover:opacity-80 transition-opacity"
            style="background: var(--theme-warning-bg, #fef3c7); color: var(--theme-warning-text, #92400e);">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M11 5L6 9H2v6h4l5 4V5z"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
      Revisão anterior possui audio
    </button>

    <button title="Histórico de IA"
            class="toolbar-btn"
            data-ai-review-target="historyButton"
            data-action="click->ai-review#openHistory">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12a9 9 0 1 0 3-6.7"/>
        <path d="M3 4v5h5"/>
        <path d="M12 7v5l3 3"/>
      </svg>
    </button>

    <div data-ai-review-target="requestMenu"
         class="hidden absolute z-40 min-w-72 rounded-xl border border-[var(--toolbar-border)] bg-[var(--theme-bg-secondary)] p-2 shadow-2xl">
      <p data-ai-review-target="requestMenuTitle"
         class="px-2 py-1 text-xs uppercase tracking-[0.18em] text-[var(--theme-text-faint)]">
        IA
      </p>
      <div data-ai-review-target="requestMenuList" class="space-y-1"></div>
    </div>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Typewriter mode toggle %>
    <button title="Modo Typewriter"
            class="toolbar-btn"
            data-action="click->editor#toggleTypewriter"
            data-editor-target="typewriterBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
    </button>

    <%# Theme picker %>
    <div class="relative flex-shrink-0" data-controller="theme">
      <button title="Tema"
              class="toolbar-btn flex items-center gap-1"
              data-action="click->theme#toggle">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <circle cx="13.5" cy="6.5" r="0.5" fill="currentColor"/>
          <circle cx="17.5" cy="10.5" r="0.5" fill="currentColor"/>
          <circle cx="8.5" cy="7.5" r="0.5" fill="currentColor"/>
          <circle cx="6.5" cy="12" r="0.5" fill="currentColor"/>
          <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 011.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"/>
        </svg>
        <span class="text-xs hidden sm:inline" data-theme-target="currentTheme">Dark</span>
      </button>
      <div class="hidden absolute right-0 top-full mt-1 w-48 rounded-lg shadow-xl py-1 z-50"
           style="background: var(--theme-bg-secondary); border: 1px solid var(--theme-border);"
           data-theme-target="menu">
      </div>
    </div>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Autosave status %>
    <span class="save-status flex-shrink-0" style="color: var(--theme-text-faint)"
          data-editor-target="saveStatus">
      —
    </span>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Revision history button + dropdown %>
    <div class="relative flex-shrink-0">
      <button title="Histórico de revisões"
              class="toolbar-btn flex-shrink-0"
              data-editor-target="revisionsButton"
              data-action="click->editor#toggleRevisions">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </button>

      <div class="hidden absolute right-0 top-full z-30 mt-2 w-96 overflow-hidden rounded-lg border bg-gray-900 shadow-2xl"
           style="border-color: var(--toolbar-border)"
           data-action="mouseleave->editor#clearRevisionPreview"
           data-editor-target="revisionsMenu">
        <ul class="max-h-80 overflow-y-auto" data-editor-target="revisionsList"></ul>
      </div>
    </div>

    <%# Save (checkpoint) button %>
    <button title="Salvar versão (checkpoint)"
            class="flex-shrink-0 flex items-center gap-1.5 rounded px-3 py-1 text-xs font-semibold text-white cursor-pointer"
            style="background: var(--theme-accent);"
            data-action="click->editor#handlePrimaryAction"
            data-editor-target="primaryActionButton">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
        <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
      </svg>
      Salvar
    </button>
  </div>

  <aside data-ai-review-target="queueDock"
         data-action="dragover->ai-review#handleQueueDockDragOver drop->ai-review#handleQueueDockDrop"
         class="fixed bottom-0 right-4 z-50 hidden flex max-h-[70vh] flex-col items-end gap-2 overflow-y-auto pb-4 pr-1 pt-2">
  </aside>

  <button type="button"
          class="typewriter-exit-btn"
          title="Sair do modo typewriter"
          data-action="click->editor#toggleTypewriter"
          data-editor-target="typewriterExitBtn"
          aria-hidden="true">
    Normal
  </button>

  <%# ── Main editor area ──────────────────────────────────── %>
  <div class="flex flex-1 min-h-0"
       data-editor-target="mainArea">

    <%# ── Tag sidebar ──────────────────────────────────────── %>
    <%
      # Preload link→tags map so JS can do highlight without extra fetches
      link_tags_map = @note.outgoing_links.includes(:tags).each_with_object({}) do |link, h|
        h[link.dst_note_id.to_s] = link.tags.map(&:id).map(&:to_s)
      end
    %>
    <div id="tag-sidebar"
         class="tag-sidebar flex-shrink-0"
         data-controller="tag-sidebar"
         data-tag-sidebar-note-slug-value="<%= @note.slug %>"
         data-tag-sidebar-link-tags-data-value="<%= link_tags_map.to_json.html_safe %>">

      <%# Header: collapse button + mode indicator %>
      <div class="tag-sidebar-header">
        <button class="tag-sidebar-toggle-btn"
                title="Toggle painel de tags"
                data-action="click->tag-sidebar#toggle">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 7l-5 5 5 5M17 7l5 5-5 5"/>
          </svg>
        </button>
        <button type="button"
                class="tag-sidebar-mode"
                data-tag-sidebar-target="modeLabel"
                data-action="click->tag-sidebar#openSearch">
          Global
        </button>
        <input type="search"
               class="tag-sidebar-search"
               placeholder="Buscar tags..."
               hidden
               data-tag-sidebar-target="searchInput"
               data-action="input->tag-sidebar#searchTags blur->tag-sidebar#closeSearch keydown->tag-sidebar#handleSearchKeydown">
      </div>

      <%# Tag list — populated and animated by JS; new-tag row appended at end by JS %>
      <ul class="tag-list" data-tag-sidebar-target="list">
        <%# New tag row — lives inside the scrollable list (JS re-appends after each render) %>
        <li class="tag-new-row" data-tag-sidebar-target="newRow">
          <%# SVG dot — opens custom color picker %>
          <button class="tag-new-dot-btn"
                  type="button"
                  title="Escolher cor"
                  data-action="click->tag-sidebar#openColorPicker"
                  data-tag-sidebar-target="newDotBtn">
          </button>
          <input type="text"
                 placeholder="Nome da tag..."
                 class="tag-new-input"
                 data-tag-sidebar-target="nameInput"
                 data-action="keydown->tag-sidebar#onNameKeydown"
                 autocomplete="off">
        </li>
      </ul>

      <%# Custom color picker popup — position:fixed, inside sidebar for Stimulus target scope %>
      <div class="tag-color-picker" hidden
           data-tag-sidebar-target="colorPicker">
        <p class="tcp-label">Sugeridas</p>
        <div class="tcp-swatches" data-tag-sidebar-target="colorSuggestions"></div>

        <p class="tcp-label">Personalizada</p>
        <canvas class="tcp-wheel-canvas" width="156" height="156"
                data-tag-sidebar-target="colorWheel"
                data-action="click->tag-sidebar#onWheelClick
                             mousemove->tag-sidebar#onWheelHover"></canvas>

        <div class="tcp-custom-row">
          <div class="tcp-preview" data-tag-sidebar-target="colorPreview"></div>
          <span class="tcp-hex" data-tag-sidebar-target="colorHex">#3b82f6</span>
          <span class="tcp-wcag tcp-wcag--aa" data-tag-sidebar-target="colorWcag">AA</span>
          <button type="button" class="tcp-confirm"
                  data-action="click->tag-sidebar#confirmCustomColor">✓</button>
        </div>
      </div>
    </div>

    <%# Editor column (editor + context panel stacked vertically) %>
    <div class="flex-1 min-w-0 flex flex-col"
         data-editor-target="editorColumn">
      <%# Editor pane %>
      <div id="editor-pane"
           class="flex-1 min-h-0 flex flex-col relative"
           data-controller="codemirror text-format stats-panel typewriter jump-to-line wikilink"
           data-codemirror-initial-value-value="<%= @revision&.content_markdown.to_s %>"
           data-wikilink-search-url-value="<%= search_notes_path %>"
           data-wikilink-create-promise-url-value="<%= create_from_promise_note_path(@note.slug) %>"
           data-wikilink-current-note-id-value="<%= @note.id %>"
           data-editor-target="editorPane">
        <div id="codemirror-host"
             class="flex-1 min-h-0 overflow-hidden"
             data-codemirror-target="host"
             data-text-format-target="editor"
             data-typewriter-target="editor"></div>

        <%# Wiki-link autocomplete dropdown %>
        <div class="wikilink-dropdown" hidden
             data-wikilink-target="dropdown"></div>

        <%# Stats bar %>
        <div class="editor-stats-bar flex items-center gap-4 px-4 py-1 flex-shrink-0"
             data-stats-panel-target="bar">
          <span data-stats-panel-target="words">0 palavras</span>
          <span data-stats-panel-target="lines">0 linhas</span>
          <span data-stats-panel-target="position">L1, C1</span>
        </div>
      </div>

      <%# Context panel (graph/backlinks) — below editor, beside preview %>
      <div class="context-panel-resize-handle flex-shrink-0"
           data-editor-target="contextResizeHandle"
           data-action="pointerdown->editor#startContextResize"></div>

      <section class="note-context-panel flex-shrink-0"
               data-editor-target="contextPanel">
        <div class="preview-layout-toolbar">
          <label class="preview-layout-toolbar__field">
            <span>Rodape</span>
            <select data-editor-target="contextMode" data-action="change->editor#updateContextMode">
              <option value="graph">Grafo</option>
              <option value="backlinks">Backlinks</option>
              <option value="hidden">Oculto</option>
            </select>
          </label>
        </div>

        <div class="note-graph-panel"
             data-editor-target="graphPanel">
          <div class="note-graph-embed"
             data-controller="graph"
             data-graph-data-url-value="<%= api_graph_path %>"
             data-graph-initial-focused-node-id-value="<%= @note.id %>"
             data-graph-embedded-mode-value="true">
            <div class="note-graph-embed__meta hidden" data-graph-target="meta">Carregando grafo...</div>
            <div class="note-graph-embed__canvas">
              <div class="note-graph-embed__host" data-graph-target="graphHost"></div>
              <div class="note-graph-embed__tooltip-layer" data-graph-target="tooltipLayer"></div>
            </div>
            <div class="note-graph-embed__empty hidden" data-graph-target="empty">
              Nenhum vizinho ficou visivel no grafo.
            </div>
            <div class="note-graph-embed__error hidden" data-graph-target="error"></div>
          </div>
        </div>

        <section class="backlinks-panel hidden"
                 data-editor-target="backlinksPanel">
          <%= render "notes/backlinks_content", note: @note %>
        </section>
      </section>
    </div>

    <%# Divider %>
    <div class="pane-divider pane-divider--draggable"
         data-editor-target="previewResizeHandle"
         data-action="pointerdown->editor#startPreviewResize"></div>

    <%# Preview pane %>
    <div id="preview-pane"
         class="flex-1 min-w-0 flex flex-col overflow-hidden"
         data-controller="preview"
         data-editor-target="previewPane">
      <section data-ai-review-target="workspace"
               class="hidden flex-1 min-h-0 flex-col bg-[var(--theme-bg-secondary)]">
        <div data-ai-review-target="configNotice"
             class="hidden flex-1 overflow-y-auto p-5">
          <div class="rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] p-5">
            <h3 class="text-base font-semibold mb-2">IA não configurada</h3>
            <p class="text-sm text-[var(--theme-text-muted)] mb-4">
              Configure ao menos um provider por ENV. Exemplos:
            </p>
            <div class="grid grid-cols-1 gap-4 text-sm">
              <pre class="bg-[var(--theme-code-bg)] p-3 rounded overflow-x-auto">OLLAMA_API_BASE=http://AIrch:11434
OLLAMA_MODEL=qwen2.5:1.5b
AI_PROVIDER=ollama
AI_ENABLED_PROVIDERS=ollama</pre>
            </div>
          </div>
        </div>

        <div data-ai-review-target="processingBox"
             class="hidden flex-1 items-center justify-center p-6">
          <div class="w-full max-w-md rounded-xl border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] p-6 shadow-lg">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full border-2 border-[var(--theme-accent)] border-t-transparent animate-spin"></div>
              <div>
                <p class="text-sm font-semibold text-[var(--theme-text-primary)]">Processando com IA</p>
                <p data-ai-review-target="processingState" class="text-sm text-[var(--theme-text-secondary)]">Na fila</p>
              </div>
            </div>
            <p data-ai-review-target="processingProvider" class="mt-4 text-sm text-[var(--theme-text-muted)]">IA</p>
            <p data-ai-review-target="processingHint" class="mt-2 text-xs text-[var(--theme-text-secondary)]">Processamento assíncrono em andamento.</p>
            <p data-ai-review-target="processingMeta" class="mt-2 text-xs text-[var(--theme-text-muted)]">Aguardando execução...</p>
            <p data-ai-review-target="processingError" class="hidden mt-2 text-xs text-amber-300"></p>
            <div class="mt-5 flex justify-end">
              <button type="button"
                      class="rounded-md border border-[var(--theme-border)] px-3 py-1.5 text-sm text-[var(--theme-text-secondary)] hover:bg-[var(--theme-bg-secondary)]"
                      data-action="click->ai-review#cancelProcessing">
                Cancelar
              </button>
            </div>
          </div>
        </div>

        <div data-ai-review-target="resultBox"
             class="hidden flex-1 min-h-0 flex-col">
          <div class="border-b border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-3">
            <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--theme-text-faint)]">Sugerido</p>
          </div>
          <div data-ai-review-target="proposalPanels"
               class="flex flex-1 min-h-0 overflow-hidden">
            <div data-ai-review-target="proposalRawPane"
                 class="hidden min-h-0 min-w-0 flex-1 flex-col overflow-hidden border-r border-[var(--theme-border)] bg-[var(--theme-bg-primary)]">
              <div class="border-b border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-3">
                <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--theme-text-faint)]">Markdown</p>
              </div>
              <textarea data-ai-review-target="correctedText"
                        class="ai-review-seed-note-editor flex-1 min-h-0 w-full resize-none border-0 bg-[var(--theme-bg-primary)] px-5 py-4 font-mono text-sm leading-relaxed text-[var(--theme-text-primary)] outline-none"
                        spellcheck="false"
                        data-action="input->ai-review#proposalChanged change->ai-review#proposalChanged"></textarea>
            </div>
            <div data-ai-review-target="proposalPreviewPane"
                 class="flex-1 min-h-0 min-w-0 overflow-y-auto bg-[var(--theme-bg-primary)]">
              <div data-ai-review-target="proposalDiff"
                   contenteditable="true"
                   spellcheck="false"
                   data-action="pointerdown->ai-review#activateSeedNoteEditing input->ai-review#proposalEditorChanged blur->ai-review#proposalEditorChanged"
                   class="ai-review-proposal-content min-h-full whitespace-pre-wrap font-mono text-sm leading-relaxed text-[var(--theme-text-primary)] outline-none"></div>
            </div>
          </div>

          <div data-ai-review-target="translationMeta"
               class="hidden border-t border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-4">
            <p data-ai-review-target="translationSummary" class="text-sm text-[var(--theme-text-secondary)]">
              Uma nova nota irma sera criada a partir desta traducao.
            </p>
            <label class="mt-3 block" for="ai-translation-title">
              <span class="mb-1 block text-xs font-medium uppercase tracking-wide text-[var(--theme-text-muted)]">
                Titulo da nova nota
              </span>
              <input type="text"
                     id="ai-translation-title"
                     data-ai-review-target="translationTitle"
                     class="w-full rounded-md border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] px-3 py-2 text-sm text-[var(--theme-text-primary)] outline-none focus:border-[var(--theme-accent)]"
                     placeholder="Titulo da nota traduzida">
            </label>
          </div>

          <footer class="flex items-center justify-between gap-3 border-t border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-4">
            <button type="button"
                    data-ai-review-target="declineButton"
                    data-action="click->ai-review#close"
                    class="rounded-md border border-[var(--theme-border)] px-4 py-2 text-sm text-[var(--theme-text-secondary)] hover:bg-[var(--theme-bg-primary)]">
              Fechar
            </button>
            <button type="button"
                    data-ai-review-target="acceptButton"
                    data-action="click->ai-review#accept"
                    class="rounded-md bg-[var(--theme-accent)] px-4 py-2 text-sm text-[var(--theme-accent-text)] hover:bg-[var(--theme-accent-hover)]">
              Aplicar
            </button>
          </footer>
        </div>
      </section>

      <div data-ai-review-target="previewShell" class="flex flex-1 min-h-0 flex-col">
        <div class="preview-prose-wrapper flex-1 min-h-0 overflow-y-auto"
             data-action="scroll->preview#scroll">
          <div class="preview-prose"
               data-editor-target="previewContent"
               data-preview-target="output">
            <p style="color: var(--theme-text-faint); font-style: italic;">Comece a digitar para ver o preview...</p>
          </div>
        </div>

      </div>
    </div>

    <%# ── Properties panel (right sidebar) ──────────────────── %>
    <% props_data = (@revision&.properties_data || {}) %>
    <div id="properties-panel"
         class="properties-panel hidden"
         data-controller="properties-panel"
         data-properties-panel-properties-url-value="<%= properties_note_path(@note.slug) %>"
         data-properties-panel-initial-definitions-value="<%= PropertyDefinition.active.order(:position, :key).map { |d| {key: d.key, value_type: d.value_type, label: d.label, description: d.description, config: d.config} }.to_json %>"
         data-properties-panel-initial-properties-value="<%= props_data.except("_errors").to_json %>"
         data-properties-panel-initial-errors-value="<%= (props_data.dig("_errors") || {}).to_json %>"
         data-editor-target="propertiesPanel">
      <div class="properties-panel-header">
        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--theme-text-faint);">Propriedades</span>
      </div>
      <div class="properties-panel-list" data-properties-panel-target="list"></div>
      <div class="properties-panel-footer">
        <div class="relative">
          <button type="button"
                  class="properties-add-btn"
                  data-properties-panel-target="addButton"
                  data-action="click->properties-panel#toggleAddDropdown">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Adicionar
          </button>
          <div class="hidden absolute left-0 bottom-full z-40 mb-1 w-full max-h-48 overflow-y-auto rounded-lg border shadow-xl"
               style="border-color: var(--toolbar-border); background: var(--theme-bg-secondary);"
               data-properties-panel-target="addDropdown">
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ── TTS Player (flex-none, pushes content up) ──── %>
  <div data-tts-target="player"
       class="hidden flex-none border-t"
       style="background: var(--theme-bg-secondary); border-color: var(--toolbar-border);">
    <div class="flex items-center gap-2 px-4 py-2 max-w-3xl mx-auto">
      <audio data-tts-target="audio" controls preload="auto"
             class="h-8 flex-1" style="min-width: 200px; max-width: 320px;"></audio>

      <span data-tts-target="playerInfo" class="text-[10px] flex-shrink-0" style="color: var(--theme-text-muted);"></span>

      <div class="flex items-center gap-0.5 text-[10px]" style="color: var(--theme-text-muted);">
        <button data-speed="0.75" data-action="click->tts#changeSpeed" class="px-1 py-0.5 rounded hover:bg-[var(--theme-bg-hover)]" title="0.75x">.75</button>
        <button data-speed="1" data-action="click->tts#changeSpeed" class="px-1 py-0.5 rounded hover:bg-[var(--theme-bg-hover)]" style="color: var(--theme-accent);" title="1x">1x</button>
        <button data-speed="1.25" data-action="click->tts#changeSpeed" class="px-1 py-0.5 rounded hover:bg-[var(--theme-bg-hover)]" title="1.25x">1.25</button>
        <button data-speed="1.5" data-action="click->tts#changeSpeed" class="px-1 py-0.5 rounded hover:bg-[var(--theme-bg-hover)]" title="1.5x">1.5</button>
      </div>

      <button title="Karaoke (texto sincronizado)"
              class="toolbar-btn"
              data-tts-target="karaokeToggle"
              data-action="click->tts#toggleKaraoke"
              style="color: var(--theme-text-muted);">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V4.846A2.25 2.25 0 0016.174 2.7L7.346 5.194A2.25 2.25 0 005.25 7.336v8.318"/>
        </svg>
      </button>

      <button title="Biblioteca de audios"
              class="toolbar-btn"
              data-action="click->tts#openDialog"
              style="color: var(--theme-text-muted);">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z"/>
        </svg>
      </button>

      <button title="Rejeitar e gerar novo"
              class="toolbar-btn text-red-400 hover:text-red-300"
              data-action="click->tts#reject">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <%# Karaoke controller — injects word spans directly into the preview pane %>
    <div data-controller="karaoke" data-tts-target="karaokeContainer" class="hidden"></div>
  </div>

  <%# ── Connection lost banner ──────────────────────────── %>
  <div id="offline-banner"
       class="hidden fixed bottom-0 left-0 right-0 px-4 py-2 text-sm text-center z-50"
       data-controller="connection-monitor"
       data-connection-monitor-target="banner">
    ⚠ Conexão perdida — as alterações serão salvas ao reconectar
  </div>

  <%# ── Find/Replace dialog ─────────────────────────────── %>
  <div id="find-replace-dialog"
       class="hidden fixed top-14 right-4 z-40 w-80 editor-dialog"
       data-controller="find-replace"
       data-find-replace-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Localizar / Substituir</span>
      <button class="toolbar-btn !p-0.5" data-action="click->find-replace#close">✕</button>
    </div>
    <div class="p-4 space-y-3">
      <div class="flex gap-2">
        <input type="text"
               placeholder="Localizar..."
               class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
               data-find-replace-target="findInput"
               data-action="input->find-replace#search keydown->find-replace#handleFindKey">
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#previous" title="Anterior">↑</button>
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#next" title="Próximo">↓</button>
      </div>
      <div class="flex gap-3 items-center">
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="caseSensitive"> Maiúsc.
        </label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="useRegex"> Regex
        </label>
        <span class="ml-auto text-xs" style="color: var(--theme-text-faint)" data-find-replace-target="matchCount">—</span>
      </div>
      <input type="text"
             placeholder="Substituir por..."
             class="editor-dialog-input w-full px-3 py-1.5 text-sm"
             data-find-replace-target="replaceInput">
      <div class="flex gap-2">
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceCurrent">Substituir</button>
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceAll">Subst. Tudo</button>
      </div>
    </div>
  </div>

  <%# ── Jump to Line dialog ────────────────────────────── %>
  <div id="jump-to-line-dialog"
       class="hidden fixed top-14 right-4 z-40 w-56 editor-dialog"
       data-jump-to-line-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Ir para Linha</span>
      <button class="toolbar-btn !p-0.5" data-action="click->jump-to-line#close">✕</button>
    </div>
    <div class="p-4 flex gap-2">
      <input type="number" min="1"
             placeholder="Número..."
             class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
             data-jump-to-line-target="lineInput"
             data-action="keydown->jump-to-line#handleKey">
      <button class="rounded px-3 py-1.5 text-xs text-white cursor-pointer"
              style="background: var(--theme-accent);"
              data-action="click->jump-to-line#jump">Ir</button>
    </div>
  </div>

  <dialog
    data-ai-review-target="historyDialog"
    class="w-[min(92vw,42rem)] max-h-[75vh] overflow-hidden p-0 rounded-lg shadow-xl bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] border border-[var(--theme-border)]"
  >
    <div class="flex h-full min-h-0 flex-col">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--theme-border)]">
        <div>
          <h2 class="text-lg font-semibold">Histórico de IA</h2>
          <p class="text-xs text-[var(--theme-text-muted)]" data-ai-review-target="historyStatus">Carregando execuções recentes...</p>
        </div>
        <div class="flex items-center gap-2">
          <button type="button"
                  class="toolbar-btn"
                  title="Atualizar histórico de IA"
                  data-action="click->ai-review#refreshHistory">
            ↻
          </button>
          <button class="toolbar-btn !p-0.5" data-action="click->ai-review#closeHistory">✕</button>
        </div>
      </div>

      <div class="min-h-0 flex-1 overflow-y-auto p-6">
        <div class="mb-4 flex flex-wrap gap-2">
          <button type="button"
                  class="ai-history-filter is-active"
                  data-ai-review-target="historyFilter"
                  data-filter-value="all"
                  data-action="click->ai-review#selectHistoryFilter">
            Todas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="queued"
                  data-action="click->ai-review#selectHistoryFilter">
            Na fila
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="active"
                  data-action="click->ai-review#selectHistoryFilter">
            Ativas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="failed"
                  data-action="click->ai-review#selectHistoryFilter">
            Falhas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="succeeded"
                  data-action="click->ai-review#selectHistoryFilter">
            Concluídas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="applicable"
                  data-action="click->ai-review#selectHistoryFilter">
            Aplicáveis
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="reopened"
                  data-action="click->ai-review#selectHistoryFilter">
            Reabertas
          </button>
        </div>
        <p class="hidden text-sm text-[var(--theme-text-muted)]" data-ai-review-target="historyEmpty">
          Nenhuma execução de IA registrada no shell.
        </p>
        <div class="space-y-3" data-ai-review-target="historyList"></div>
      </div>
    </div>
  </dialog>

  <%# ── Emoji Picker Dialog ──────────────────────────────── %>
  <div data-controller="emoji-picker"
       data-emoji-picker-columns-value="10"
       data-emoji-picker-emoticon-columns-value="5">
    <dialog class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 w-[500px] max-h-[70vh] dialog-centered"
            style="background: var(--theme-bg-secondary); border: 1px solid var(--theme-border);"
            data-emoji-picker-target="dialog">
      <div class="flex flex-col h-full max-h-[70vh]">
        <%# Header with tabs and search %>
        <div class="flex-none p-3" style="border-bottom: 1px solid var(--theme-border);">
          <div class="flex items-center justify-between mb-2">
            <div class="flex gap-1" role="tablist">
              <button type="button" role="tab"
                      data-emoji-picker-target="tabEmoji"
                      data-action="click->emoji-picker#switchToEmoji"
                      class="px-3 py-1 text-sm rounded-md cursor-pointer"
                      style="background: var(--theme-accent); color: var(--theme-accent-text);">
                Emoji
              </button>
              <button type="button" role="tab"
                      data-emoji-picker-target="tabEmoticons"
                      data-action="click->emoji-picker#switchToEmoticons"
                      class="px-3 py-1 text-sm rounded-md cursor-pointer"
                      style="color: var(--theme-text-muted);">
                Emoticons
              </button>
            </div>
            <button type="button"
                    class="p-1 rounded cursor-pointer"
                    style="color: var(--theme-text-muted);"
                    data-action="click->emoji-picker#close"
                    title="Fechar">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <input type="text"
                 data-emoji-picker-target="input"
                 data-action="input->emoji-picker#onInput keydown->emoji-picker#onKeydown"
                 class="w-full px-3 py-2 text-sm rounded-md focus:outline-none focus:ring-2"
                 style="border: 1px solid var(--theme-border); background: var(--theme-bg-primary); color: var(--theme-text-primary); --tw-ring-color: var(--theme-accent);"
                 placeholder="Buscar emoji..."
                 autocomplete="off"
                 spellcheck="false">
        </div>
        <%# Grid %>
        <div class="flex-1 overflow-y-auto p-3 min-h-0">
          <div data-emoji-picker-target="grid"
               class="grid gap-1"
               style="grid-template-columns: repeat(10, minmax(0, 1fr));">
          </div>
        </div>
        <%# Preview footer %>
        <div class="flex-none p-3" style="border-top: 1px solid var(--theme-border); background: var(--theme-bg-tertiary);">
          <div data-emoji-picker-target="preview"
               class="flex items-center justify-center gap-3 h-12"
               style="color: var(--theme-text-primary);">
          </div>
        </div>
      </div>
    </dialog>
  </div>

  <%# ── Table Editor Dialog ─────────────────────────────── %>
  <div data-controller="table-editor">
    <dialog class="p-0 rounded-lg shadow-xl backdrop:bg-black/50 max-w-3xl"
            style="background: var(--theme-bg-secondary); border: 1px solid var(--theme-border);"
            data-table-editor-target="dialog"
            tabindex="-1">
      <div class="p-4" style="color: var(--theme-text-primary);">
        <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
          <h3 class="text-base font-semibold">Editor de Tabela</h3>
          <div class="flex items-center gap-3 flex-wrap">
            <div class="flex flex-col items-start gap-1">
              <span class="text-xs uppercase tracking-wide font-semibold" style="color: var(--theme-text-muted);">Colunas</span>
              <div class="table-editor-stepper">
                <input type="number" min="1" step="1" value="3" inputmode="numeric"
                       data-table-editor-target="columnCountInput"
                       data-action="change->table-editor#setColumnCount"
                       aria-label="Colunas">
                <div class="table-editor-stepper-buttons">
                  <button type="button" class="table-editor-stepper-btn"
                          data-action="click->table-editor#decrementColumnCount" title="Remover coluna">-</button>
                  <button type="button" class="table-editor-stepper-btn"
                          data-action="click->table-editor#incrementColumnCount" title="Adicionar coluna">+</button>
                </div>
              </div>
            </div>
            <div class="flex flex-col items-start gap-1">
              <span class="text-xs uppercase tracking-wide font-semibold" style="color: var(--theme-text-muted);">Linhas</span>
              <div class="table-editor-stepper">
                <input type="number" min="1" step="1" value="3" inputmode="numeric"
                       data-table-editor-target="rowCountInput"
                       data-action="change->table-editor#setRowCount"
                       aria-label="Linhas">
                <div class="table-editor-stepper-buttons">
                  <button type="button" class="table-editor-stepper-btn"
                          data-action="click->table-editor#decrementRowCount" title="Remover linha">-</button>
                  <button type="button" class="table-editor-stepper-btn"
                          data-action="click->table-editor#incrementRowCount" title="Adicionar linha">+</button>
                </div>
              </div>
            </div>
          </div>
        </div>

        <%# Cell Context Menu %>
        <div class="fixed hidden rounded-lg shadow-lg py-1 min-w-[140px] z-[60]"
             style="background: var(--theme-bg-secondary); border: 1px solid var(--theme-border); color: var(--theme-text-primary);"
             data-table-editor-target="cellMenu">
          <div class="px-2 py-1 text-xs font-semibold uppercase" style="color: var(--theme-text-muted);">Coluna</div>
          <button type="button" data-action="click->table-editor#moveColumnLeft" data-table-editor-target="moveColLeftBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Mover esquerda
          </button>
          <button type="button" data-action="click->table-editor#moveColumnRight" data-table-editor-target="moveColRightBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            Mover direita
          </button>
          <button type="button" data-action="click->table-editor#deleteColumnAt" data-table-editor-target="deleteColBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="color: var(--theme-error); cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Excluir coluna
          </button>
          <div class="my-1" style="border-top: 1px solid var(--theme-border);"></div>
          <div class="px-2 py-1 text-xs font-semibold uppercase" style="color: var(--theme-text-muted);">Linha</div>
          <button type="button" data-action="click->table-editor#moveRowUp" data-table-editor-target="moveRowUpBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
            Mover cima
          </button>
          <button type="button" data-action="click->table-editor#moveRowDown" data-table-editor-target="moveRowDownBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            Mover baixo
          </button>
          <button type="button" data-action="click->table-editor#deleteRowAt" data-table-editor-target="deleteRowBtn"
                  class="w-full px-3 py-1.5 text-left text-sm flex items-center gap-2" style="color: var(--theme-error); cursor:pointer;" onmouseover="this.style.background='var(--theme-bg-hover)'" onmouseout="this.style.background='transparent'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Excluir linha
          </button>
        </div>

        <%# Table Grid %>
        <div class="overflow-auto max-h-80 rounded-md" style="border: 1px solid var(--theme-border);" data-table-editor-target="grid"></div>

        <div class="flex items-center justify-end mt-4 gap-2">
          <button type="button"
                  class="px-3 py-1.5 text-sm rounded cursor-pointer"
                  style="border: 1px solid var(--theme-border); color: var(--theme-text-secondary);"
                  data-action="click->table-editor#close">
            Cancelar
          </button>
          <button type="button"
                  class="px-3 py-1.5 text-sm rounded cursor-pointer"
                  style="background: var(--theme-accent); color: var(--theme-accent-text);"
                  data-action="click->table-editor#insert">
            Inserir Tabela
          </button>
        </div>
      </div>
    </dialog>
  </div>

  <%# ── Shortcuts Help Dialog ───────────────────────────── %>
  <dialog id="shortcuts-help-dialog"
          class="p-0 rounded-xl shadow-2xl backdrop:bg-black/50 max-w-lg w-full dialog-centered"
          style="background: var(--theme-bg-secondary); border: 1px solid var(--theme-border); color: var(--theme-text-primary);">
    <div class="p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Atalhos do Teclado</h3>
        <form method="dialog">
          <button class="toolbar-btn" title="Fechar">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </form>
      </div>
      <div class="grid grid-cols-2 gap-x-2 gap-y-1.5 text-sm" style="color: var(--theme-text-secondary);">
        <span class="font-semibold col-span-2 mt-2 mb-1" style="color: var(--theme-text-primary);">Formatacao</span>
        <span><kbd>Ctrl+B</kbd></span><span>Negrito</span>
        <span><kbd>Ctrl+I</kbd></span><span>Italico</span>
        <span><kbd>Ctrl+K</kbd></span><span>Link</span>
        <span><kbd>Ctrl+`</kbd></span><span>Codigo inline</span>
        <span><kbd>Ctrl+Shift+S</kbd></span><span>Tachado</span>
        <span><kbd>Ctrl+Shift+H</kbd></span><span>Destaque</span>
        <span><kbd>Ctrl+Shift+C</kbd></span><span>Bloco de codigo</span>

        <span class="font-semibold col-span-2 mt-3 mb-1" style="color: var(--theme-text-primary);">Navegacao</span>
        <span><kbd>Ctrl+P</kbd></span><span>Toggle preview</span>
        <span><kbd>Ctrl+F</kbd></span><span>Buscar</span>
        <span><kbd>Ctrl+H</kbd></span><span>Buscar e substituir</span>
        <span><kbd>Ctrl+G</kbd></span><span>Ir para linha</span>
        <span><kbd>Ctrl+Shift+K</kbd></span><span>Buscar nota</span>

        <span class="font-semibold col-span-2 mt-3 mb-1" style="color: var(--theme-text-primary);">Ferramentas</span>
        <span><kbd>Ctrl+Shift+E</kbd></span><span>Emoji picker</span>
        <span><kbd>Ctrl+Shift+A</kbd></span><span>Audio (TTS)</span>
        <span><kbd>Ctrl+\</kbd></span><span>Modo typewriter</span>
        <span><kbd>F1</kbd></span><span>Este menu</span>
        <span><kbd>Esc</kbd></span><span>Fechar dialogos</span>
      </div>
    </div>
  </dialog>

</div>
