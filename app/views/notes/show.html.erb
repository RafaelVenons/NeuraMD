<% content_for :title, "#{@note.title} — NeuraMD" %>

<div id="editor-root"
     class="flex flex-col"
     style="height: 100dvh; background: var(--theme-bg-primary);"
     data-controller="editor autosave"
     data-editor-autosave-url-value="<%= draft_note_path(@note.slug) %>"
     data-editor-revisions-url-value="<%= revisions_note_path(@note.slug) %>"
     data-editor-slug-value="<%= @note.slug %>"
     data-editor-title-value="<%= @note.title %>"
     data-editor-language-value="<%= @note.detected_language %>"
     data-editor-initial-revision-id-value="<%= @revision&.id %>"
     data-editor-initial-revision-kind-value="<%= @revision&.revision_kind %>"
     data-editor-head-revision-id-value="<%= @note.head_revision_id %>"
     data-autosave-draft-url-value="<%= draft_note_path(@note.slug) %>"
     data-autosave-checkpoint-url-value="<%= checkpoint_note_path(@note.slug) %>"
     data-autosave-local-key-value="note-draft-<%= @note.id %>"
     data-autosave-server-updated-at-value="<%= @revision&.updated_at&.iso8601 %>"
     data-autosave-draft-ms-value="60000"
     data-autosave-local-ms-value="3000">

  <%# ── Toolbar ─────────────────────────────────────────── %>
  <div id="editor-toolbar"
       class="flex items-center gap-2 border-b border-gray-800 bg-gray-900 px-3 py-2 flex-shrink-0">

    <%# Back link %>
    <%= link_to notes_path,
        class: "flex-shrink-0 rounded p-1.5 text-gray-400 hover:bg-gray-800 hover:text-gray-200",
        title: "Voltar para lista",
        "data-turbo-prefetch": "false" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
    <% end %>

    <%# Editable title %>
    <input type="text"
           value="<%= @note.title %>"
           class="flex-1 min-w-0 bg-transparent text-sm font-medium text-gray-200 placeholder-gray-500 outline-none border-b border-transparent focus:border-gray-600 py-0.5"
           data-editor-target="titleInput"
           placeholder="Título da nota">

    <%# Language badge %>
    <span class="flex-shrink-0 rounded bg-gray-800 px-2 py-0.5 text-xs font-mono text-gray-400"
          data-editor-target="langBadge">
      <%= @note.detected_language || "auto" %>
    </span>

    <%# Format buttons %>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <button title="Negrito (Ctrl+B)"
              class="toolbar-btn"
              data-action="click->text-format#bold">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 12h8a4 4 0 000-8H6v8zm0 0h9a4 4 0 010 8H6v-8z"/>
        </svg>
      </button>
      <button title="Itálico (Ctrl+I)"
              class="toolbar-btn"
              data-action="click->text-format#italic">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/>
          <line x1="15" y1="4" x2="9" y2="20"/>
        </svg>
      </button>
      <button title="Código (Ctrl+`)"
              class="toolbar-btn"
              data-action="click->text-format#inlineCode">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
      </button>
      <button title="Link (Ctrl+K)"
              class="toolbar-btn"
              data-action="click->text-format#link">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
        </svg>
      </button>
    </div>

    <%# Divider %>
    <div class="w-px h-5 bg-gray-700 flex-shrink-0"></div>

    <%# Preview toggle %>
    <button title="Buscar notas (Ctrl+Shift+K)"
            class="toolbar-btn"
            data-action="click->note-finder#open">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
    </button>

    <button title="Toggle Preview (Ctrl+P)"
            class="toolbar-btn"
            data-action="click->editor#togglePreview"
            data-editor-target="previewToggleBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    </button>

    <%# Typewriter mode toggle %>
    <button title="Modo Typewriter"
            class="toolbar-btn"
            data-action="click->typewriter#toggle"
            data-editor-target="typewriterBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
    </button>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Autosave status %>
    <span class="save-status flex-shrink-0" style="color: var(--theme-text-faint)"
          data-editor-target="saveStatus">
      —
    </span>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Revision history button + dropdown %>
    <div class="relative flex-shrink-0">
      <button title="Histórico de revisões"
              class="toolbar-btn flex-shrink-0"
              data-editor-target="revisionsButton"
              data-action="click->editor#toggleRevisions">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </button>

      <div class="hidden absolute right-0 top-full z-30 mt-2 w-96 overflow-hidden rounded-lg border bg-gray-900 shadow-2xl"
           style="border-color: var(--toolbar-border)"
           data-action="mouseleave->editor#clearRevisionPreview"
           data-editor-target="revisionsMenu">
        <ul class="max-h-80 overflow-y-auto" data-editor-target="revisionsList"></ul>
      </div>
    </div>

    <%# Save (checkpoint) button %>
    <button title="Salvar versão (checkpoint)"
            class="flex-shrink-0 flex items-center gap-1.5 rounded px-3 py-1 text-xs font-semibold text-white cursor-pointer"
            style="background: var(--theme-accent);"
            data-action="click->editor#handlePrimaryAction"
            data-editor-target="primaryActionButton">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
        <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
      </svg>
      Salvar
    </button>
  </div>

  <%# ── Main editor area ──────────────────────────────────── %>
  <div class="flex flex-1 min-h-0"
       data-editor-target="mainArea">

    <%# ── Tag sidebar ──────────────────────────────────────── %>
    <%
      # Preload link→tags map so JS can do highlight without extra fetches
      link_tags_map = @note.outgoing_links.includes(:tags).each_with_object({}) do |link, h|
        h[link.dst_note_id.to_s] = link.tags.map(&:id).map(&:to_s)
      end
    %>
    <div id="tag-sidebar"
         class="tag-sidebar flex-shrink-0"
         data-controller="tag-sidebar"
         data-tag-sidebar-note-slug-value="<%= @note.slug %>"
         data-tag-sidebar-link-tags-data-value="<%= link_tags_map.to_json.html_safe %>">

      <%# Header: collapse button + mode indicator %>
      <div class="tag-sidebar-header">
        <button class="tag-sidebar-toggle-btn"
                title="Toggle painel de tags"
                data-action="click->tag-sidebar#toggle">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 7l-5 5 5 5M17 7l5 5-5 5"/>
          </svg>
        </button>
        <button type="button"
                class="tag-sidebar-mode"
                data-tag-sidebar-target="modeLabel"
                data-action="click->tag-sidebar#openSearch">
          Global
        </button>
        <input type="search"
               class="tag-sidebar-search"
               placeholder="Buscar tags..."
               hidden
               data-tag-sidebar-target="searchInput"
               data-action="input->tag-sidebar#searchTags blur->tag-sidebar#closeSearch keydown->tag-sidebar#handleSearchKeydown">
      </div>

      <%# Tag list — populated and animated by JS; new-tag row appended at end by JS %>
      <ul class="tag-list" data-tag-sidebar-target="list">
        <%# New tag row — lives inside the scrollable list (JS re-appends after each render) %>
        <li class="tag-new-row" data-tag-sidebar-target="newRow">
          <%# SVG dot — opens custom color picker %>
          <button class="tag-new-dot-btn"
                  type="button"
                  title="Escolher cor"
                  data-action="click->tag-sidebar#openColorPicker"
                  data-tag-sidebar-target="newDotBtn">
          </button>
          <input type="text"
                 placeholder="Nome da tag..."
                 class="tag-new-input"
                 data-tag-sidebar-target="nameInput"
                 data-action="keydown->tag-sidebar#onNameKeydown"
                 autocomplete="off">
        </li>
      </ul>

      <%# Custom color picker popup — position:fixed, inside sidebar for Stimulus target scope %>
      <div class="tag-color-picker" hidden
           data-tag-sidebar-target="colorPicker">
        <p class="tcp-label">Sugeridas</p>
        <div class="tcp-swatches" data-tag-sidebar-target="colorSuggestions"></div>

        <p class="tcp-label">Personalizada</p>
        <canvas class="tcp-wheel-canvas" width="156" height="156"
                data-tag-sidebar-target="colorWheel"
                data-action="click->tag-sidebar#onWheelClick
                             mousemove->tag-sidebar#onWheelHover"></canvas>

        <div class="tcp-custom-row">
          <div class="tcp-preview" data-tag-sidebar-target="colorPreview"></div>
          <span class="tcp-hex" data-tag-sidebar-target="colorHex">#3b82f6</span>
          <span class="tcp-wcag tcp-wcag--aa" data-tag-sidebar-target="colorWcag">AA</span>
          <button type="button" class="tcp-confirm"
                  data-action="click->tag-sidebar#confirmCustomColor">✓</button>
        </div>
      </div>
    </div>

    <%# Editor pane %>
    <div id="editor-pane"
         class="flex-1 min-w-0 flex flex-col relative"
         data-controller="codemirror text-format stats-panel typewriter jump-to-line wikilink"
         data-codemirror-initial-value-value="<%= @revision&.content_markdown.to_s %>"
         data-wikilink-search-url-value="<%= search_notes_path %>"
         data-wikilink-current-note-id-value="<%= @note.id %>"
         data-editor-target="editorPane">
      <div id="codemirror-host"
           class="flex-1 min-h-0 overflow-hidden"
           data-codemirror-target="host"
           data-text-format-target="editor"
           data-typewriter-target="editor"></div>

      <%# Wiki-link autocomplete dropdown %>
      <div class="wikilink-dropdown" hidden
           data-wikilink-target="dropdown"></div>

      <%# Stats bar %>
      <div class="editor-stats-bar flex items-center gap-4 px-4 py-1 flex-shrink-0"
           data-stats-panel-target="bar">
        <span data-stats-panel-target="words">0 palavras</span>
        <span data-stats-panel-target="lines">0 linhas</span>
        <span data-stats-panel-target="position">L1, C1</span>
      </div>
    </div>

    <%# Divider %>
    <div class="pane-divider"></div>

    <%# Preview pane %>
    <div id="preview-pane"
         class="flex-1 min-w-0 overflow-y-auto flex flex-col"
         data-controller="preview"
         data-editor-target="previewPane"
         data-action="scroll->preview#scroll">
      <div class="preview-prose flex-1"
           data-preview-target="output">
        <p style="color: var(--theme-text-faint); font-style: italic;">Comece a digitar para ver o preview...</p>
      </div>

      <%# Backlinks — grouped by semantic role with inverted colours %>
      <%
        incoming = @note.incoming_links.includes(:src_note)
        fathers  = incoming.select { |l| l.hier_role == "target_is_child"   }.map(&:src_note).compact
        brothers = incoming.select { |l| l.hier_role == "same_level"        }.map(&:src_note).compact
        children = incoming.select { |l| l.hier_role == "target_is_parent"  }.map(&:src_note).compact
        plain    = incoming.select { |l| l.hier_role.nil?                   }.map(&:src_note).compact
      %>
      <% if fathers.any? || brothers.any? || children.any? || plain.any? %>
        <div class="backlinks-panel px-6 pb-8">
          <% if fathers.any? %>
            <div class="backlinks-group">
              <span class="backlinks-group-label">Fathers:</span>
              <ul class="backlinks-list">
                <% fathers.each do |n| %>
                  <li><%= link_to n.title, note_path(n.slug), class: "backlink-child" %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <% if brothers.any? %>
            <div class="backlinks-group">
              <span class="backlinks-group-label">Brothers:</span>
              <ul class="backlinks-list">
                <% brothers.each do |n| %>
                  <li><%= link_to n.title, note_path(n.slug), class: "backlink-brother" %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <% if children.any? %>
            <div class="backlinks-group">
              <span class="backlinks-group-label">Children:</span>
              <ul class="backlinks-list">
                <% children.each do |n| %>
                  <li><%= link_to n.title, note_path(n.slug), class: "backlink-father" %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <% if plain.any? %>
            <div class="backlinks-group">
              <ul class="backlinks-list">
                <% plain.each do |n| %>
                  <li><%= link_to n.title, note_path(n.slug), class: "backlink-null" %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Connection lost banner ──────────────────────────── %>
  <div id="offline-banner"
       class="hidden fixed bottom-0 left-0 right-0 px-4 py-2 text-sm text-center z-50"
       data-controller="connection-monitor"
       data-connection-monitor-target="banner">
    ⚠ Conexão perdida — as alterações serão salvas ao reconectar
  </div>

  <%# ── Find/Replace dialog ─────────────────────────────── %>
  <div id="find-replace-dialog"
       class="hidden fixed top-14 right-4 z-40 w-80 editor-dialog"
       data-controller="find-replace"
       data-find-replace-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Localizar / Substituir</span>
      <button class="toolbar-btn !p-0.5" data-action="click->find-replace#close">✕</button>
    </div>
    <div class="p-4 space-y-3">
      <div class="flex gap-2">
        <input type="text"
               placeholder="Localizar..."
               class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
               data-find-replace-target="findInput"
               data-action="input->find-replace#search keydown->find-replace#handleFindKey">
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#previous" title="Anterior">↑</button>
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#next" title="Próximo">↓</button>
      </div>
      <div class="flex gap-3 items-center">
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="caseSensitive"> Maiúsc.
        </label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="useRegex"> Regex
        </label>
        <span class="ml-auto text-xs" style="color: var(--theme-text-faint)" data-find-replace-target="matchCount">—</span>
      </div>
      <input type="text"
             placeholder="Substituir por..."
             class="editor-dialog-input w-full px-3 py-1.5 text-sm"
             data-find-replace-target="replaceInput">
      <div class="flex gap-2">
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceCurrent">Substituir</button>
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceAll">Subst. Tudo</button>
      </div>
    </div>
  </div>

  <%# ── Jump to Line dialog ────────────────────────────── %>
  <div id="jump-to-line-dialog"
       class="hidden fixed top-14 right-4 z-40 w-56 editor-dialog"
       data-jump-to-line-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Ir para Linha</span>
      <button class="toolbar-btn !p-0.5" data-action="click->jump-to-line#close">✕</button>
    </div>
    <div class="p-4 flex gap-2">
      <input type="number" min="1"
             placeholder="Número..."
             class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
             data-jump-to-line-target="lineInput"
             data-action="keydown->jump-to-line#handleKey">
      <button class="rounded px-3 py-1.5 text-xs text-white cursor-pointer"
              style="background: var(--theme-accent);"
              data-action="click->jump-to-line#jump">Ir</button>
    </div>
  </div>

</div>
