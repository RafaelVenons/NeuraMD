<% content_for :title, "#{@note.title} — NeuraMD" %>

<div id="editor-root"
     class="flex flex-col"
     style="height: 100dvh; background: var(--theme-bg-primary);"
     data-controller="note-shell editor autosave ai-review"
     data-note-shell-target="root"
     data-editor-autosave-url-value="<%= draft_note_path(@note.slug) %>"
     data-editor-revisions-url-value="<%= revisions_note_path(@note.slug) %>"
     data-editor-slug-value="<%= @note.slug %>"
     data-editor-title-value="<%= @note.title %>"
     data-editor-language-value="<%= @note.detected_language %>"
     data-editor-focus-title-value="<%= params[:focus] == 'title' %>"
     data-editor-initial-revision-id-value="<%= @revision&.id %>"
     data-editor-initial-revision-kind-value="<%= @revision&.revision_kind %>"
     data-editor-head-revision-id-value="<%= @note.head_revision_id %>"
     data-ai-review-queue-url-value="<%= ai_requests_dashboard_path(format: :json) %>"
     data-ai-review-queue-reorder-url-value="<%= reorder_ai_requests_dashboard_path %>"
     data-ai-review-queue-request-url-template-value="<%= ai_request_payload_path("__REQUEST_ID__") %>"
     data-ai-review-queue-retry-url-template-value="<%= retry_ai_request_path("__REQUEST_ID__") %>"
     data-ai-review-queue-cancel-url-template-value="<%= ai_request_dashboard_path("__REQUEST_ID__") %>"
     data-ai-review-queue-resolve-url-template-value="<%= resolve_ai_request_queue_path("__REQUEST_ID__") %>"
     data-ai-review-status-url-value="<%= ai_status_note_path(@note.slug) %>"
     data-ai-review-review-url-value="<%= ai_review_note_path(@note.slug) %>"
     data-ai-review-history-url-value="<%= ai_requests_note_path(@note.slug) %>"
     data-ai-review-reorder-url-value="<%= reorder_ai_requests_note_path(@note.slug) %>"
     data-ai-review-request-url-template-value="<%= ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-retry-url-template-value="<%= retry_ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-cancel-url-template-value="<%= ai_request_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-resolve-url-template-value="<%= resolve_ai_request_queue_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-create-translated-note-url-template-value="<%= ai_request_translated_note_note_path(@note.slug, "__REQUEST_ID__") %>"
     data-ai-review-note-title-value="<%= @note.title %>"
     data-ai-review-note-language-value="<%= @note.detected_language %>"
     data-ai-review-language-options-value="<%= Note::SUPPORTED_LANGUAGES.reject { |lang| lang == @note.detected_language }.to_json %>"
     data-ai-review-language-labels-value="<%= Notes::TranslationNoteService::LANGUAGE_LABELS.to_json %>"
     data-autosave-draft-url-value="<%= draft_note_path(@note.slug) %>"
     data-autosave-checkpoint-url-value="<%= checkpoint_note_path(@note.slug) %>"
     data-autosave-local-key-value="note-draft-<%= @note.id %>"
     data-autosave-server-updated-at-value="<%= @revision&.updated_at&.iso8601 %>"
     data-autosave-draft-ms-value="60000"
     data-autosave-local-ms-value="3000">

  <div data-note-shell-target="streamSource">
    <%= render "notes/ai_requests_stream", note: @note %>
  </div>

  <%# ── Toolbar ─────────────────────────────────────────── %>
  <div id="editor-toolbar"
       class="flex items-center gap-2 border-b border-gray-800 bg-gray-900 px-3 py-2 flex-shrink-0">

    <%# Back link %>
    <%= link_to graph_path,
        class: "flex-shrink-0 rounded p-1.5 text-gray-400 hover:bg-gray-800 hover:text-gray-200",
        title: "Voltar para o grafo",
        data: { turbo_prefetch: false, action: "click->page-transition#navigate", transition_kind: "note-to-graph" } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
    <% end %>

    <%# Editable title %>
    <input type="text"
           value="<%= @note.title %>"
           class="flex-1 min-w-0 bg-transparent text-sm font-medium text-gray-200 placeholder-gray-500 outline-none border-b border-transparent focus:border-gray-600 py-0.5"
           data-editor-target="titleInput"
           placeholder="Título da nota">

    <%# Language badge %>
    <span class="flex-shrink-0 rounded bg-gray-800 px-2 py-0.5 text-xs font-mono text-gray-400"
          data-editor-target="langBadge">
      <%= @note.detected_language || "auto" %>
    </span>

    <span class="nm-ai-transport nm-ai-transport--fallback"
          data-ai-review-target="transportBadge">
      Fallback polling
    </span>

    <%# Format buttons %>
    <div class="flex items-center gap-0.5 flex-shrink-0">
      <button title="Negrito (Ctrl+B)"
              class="toolbar-btn"
              data-action="click->text-format#bold">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 12h8a4 4 0 000-8H6v8zm0 0h9a4 4 0 010 8H6v-8z"/>
        </svg>
      </button>
      <button title="Itálico (Ctrl+I)"
              class="toolbar-btn"
              data-action="click->text-format#italic">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/>
          <line x1="15" y1="4" x2="9" y2="20"/>
        </svg>
      </button>
      <button title="Código (Ctrl+`)"
              class="toolbar-btn"
              data-action="click->text-format#inlineCode">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
      </button>
      <button title="Link (Ctrl+K)"
              class="toolbar-btn"
              data-action="click->text-format#link">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
        </svg>
      </button>
    </div>

    <%# Divider %>
    <div class="w-px h-5 bg-gray-700 flex-shrink-0"></div>

    <%# Preview toggle %>
    <button title="Buscar notas (Ctrl+Shift+K)"
            class="toolbar-btn"
            data-action="click->note-finder#open">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
    </button>

    <button title="Toggle Preview (Ctrl+P)"
            class="toolbar-btn"
            data-action="click->editor#togglePreview"
            data-editor-target="previewToggleBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
    </button>

    <button title="Sugestão com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openSuggest">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 3l1.9 4.6L18.5 9l-4.6 1.4L12 15l-1.9-4.6L5.5 9l4.6-1.4L12 3z"/>
        <path d="M19 15l.95 2.05L22 18l-2.05.95L19 21l-.95-2.05L16 18l2.05-.95L19 15z"/>
      </svg>
    </button>

    <button title="Reescrever com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openRewrite">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 20h4l10.5-10.5a2.1 2.1 0 0 0-4-4L4 16v4z"/>
        <path d="M13.5 6.5l4 4"/>
      </svg>
    </button>

    <button title="Revisar gramática com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openGrammar">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 19.5V5a2 2 0 0 1 2-2h8l6 6v10.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/>
        <path d="M14 3v6h6"/>
        <path d="M8 13h8M8 17h5"/>
      </svg>
    </button>

    <button title="Traduzir com IA"
            class="toolbar-btn"
            data-action="click->ai-review#openTranslate">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 8h14"/>
        <path d="M9 5v3c0 4-2 7-5 9"/>
        <path d="M15 11l4 8"/>
        <path d="M13 19l4-8 4 8"/>
      </svg>
    </button>

    <button title="Histórico de IA"
            class="toolbar-btn"
            data-action="click->ai-review#openHistory">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12a9 9 0 1 0 3-6.7"/>
        <path d="M3 4v5h5"/>
        <path d="M12 7v5l3 3"/>
      </svg>
    </button>

    <div data-ai-review-target="requestMenu"
         class="hidden absolute z-40 min-w-72 rounded-xl border border-[var(--toolbar-border)] bg-[var(--theme-bg-secondary)] p-2 shadow-2xl">
      <p data-ai-review-target="requestMenuTitle"
         class="px-2 py-1 text-xs uppercase tracking-[0.18em] text-[var(--theme-text-faint)]">
        IA
      </p>
      <div data-ai-review-target="requestMenuList" class="space-y-1"></div>
    </div>

    <%# Typewriter mode toggle %>
    <button title="Modo Typewriter"
            class="toolbar-btn"
            data-action="click->typewriter#toggle"
            data-editor-target="typewriterBtn">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <line x1="8" y1="12" x2="16" y2="12"/>
      </svg>
    </button>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Autosave status %>
    <span class="save-status flex-shrink-0" style="color: var(--theme-text-faint)"
          data-editor-target="saveStatus">
      —
    </span>

    <%# Divider %>
    <div class="w-px h-5 flex-shrink-0" style="background: var(--toolbar-border)"></div>

    <%# Revision history button + dropdown %>
    <div class="relative flex-shrink-0">
      <button title="Histórico de revisões"
              class="toolbar-btn flex-shrink-0"
              data-editor-target="revisionsButton"
              data-action="click->editor#toggleRevisions">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </button>

      <div class="hidden absolute right-0 top-full z-30 mt-2 w-96 overflow-hidden rounded-lg border bg-gray-900 shadow-2xl"
           style="border-color: var(--toolbar-border)"
           data-action="mouseleave->editor#clearRevisionPreview"
           data-editor-target="revisionsMenu">
        <ul class="max-h-80 overflow-y-auto" data-editor-target="revisionsList"></ul>
      </div>
    </div>

    <%# Save (checkpoint) button %>
    <button title="Salvar versão (checkpoint)"
            class="flex-shrink-0 flex items-center gap-1.5 rounded px-3 py-1 text-xs font-semibold text-white cursor-pointer"
            style="background: var(--theme-accent);"
            data-action="click->editor#handlePrimaryAction"
            data-editor-target="primaryActionButton">
      <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
        <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
      </svg>
      Salvar
    </button>
  </div>

  <aside data-ai-review-target="queueDock"
         data-action="dragover->ai-review#handleQueueDockDragOver drop->ai-review#handleQueueDockDrop"
         class="fixed bottom-0 right-4 z-50 hidden flex max-h-[70vh] flex-col items-end gap-2 overflow-y-auto pb-4 pr-1 pt-2">
  </aside>

  <%# ── Main editor area ──────────────────────────────────── %>
  <div class="flex flex-1 min-h-0"
       data-editor-target="mainArea">

    <%# ── Tag sidebar ──────────────────────────────────────── %>
    <%
      # Preload link→tags map so JS can do highlight without extra fetches
      link_tags_map = @note.outgoing_links.includes(:tags).each_with_object({}) do |link, h|
        h[link.dst_note_id.to_s] = link.tags.map(&:id).map(&:to_s)
      end
    %>
    <div id="tag-sidebar"
         class="tag-sidebar flex-shrink-0"
         data-controller="tag-sidebar"
         data-tag-sidebar-note-slug-value="<%= @note.slug %>"
         data-tag-sidebar-link-tags-data-value="<%= link_tags_map.to_json.html_safe %>">

      <%# Header: collapse button + mode indicator %>
      <div class="tag-sidebar-header">
        <button class="tag-sidebar-toggle-btn"
                title="Toggle painel de tags"
                data-action="click->tag-sidebar#toggle">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 7l-5 5 5 5M17 7l5 5-5 5"/>
          </svg>
        </button>
        <button type="button"
                class="tag-sidebar-mode"
                data-tag-sidebar-target="modeLabel"
                data-action="click->tag-sidebar#openSearch">
          Global
        </button>
        <input type="search"
               class="tag-sidebar-search"
               placeholder="Buscar tags..."
               hidden
               data-tag-sidebar-target="searchInput"
               data-action="input->tag-sidebar#searchTags blur->tag-sidebar#closeSearch keydown->tag-sidebar#handleSearchKeydown">
      </div>

      <%# Tag list — populated and animated by JS; new-tag row appended at end by JS %>
      <ul class="tag-list" data-tag-sidebar-target="list">
        <%# New tag row — lives inside the scrollable list (JS re-appends after each render) %>
        <li class="tag-new-row" data-tag-sidebar-target="newRow">
          <%# SVG dot — opens custom color picker %>
          <button class="tag-new-dot-btn"
                  type="button"
                  title="Escolher cor"
                  data-action="click->tag-sidebar#openColorPicker"
                  data-tag-sidebar-target="newDotBtn">
          </button>
          <input type="text"
                 placeholder="Nome da tag..."
                 class="tag-new-input"
                 data-tag-sidebar-target="nameInput"
                 data-action="keydown->tag-sidebar#onNameKeydown"
                 autocomplete="off">
        </li>
      </ul>

      <%# Custom color picker popup — position:fixed, inside sidebar for Stimulus target scope %>
      <div class="tag-color-picker" hidden
           data-tag-sidebar-target="colorPicker">
        <p class="tcp-label">Sugeridas</p>
        <div class="tcp-swatches" data-tag-sidebar-target="colorSuggestions"></div>

        <p class="tcp-label">Personalizada</p>
        <canvas class="tcp-wheel-canvas" width="156" height="156"
                data-tag-sidebar-target="colorWheel"
                data-action="click->tag-sidebar#onWheelClick
                             mousemove->tag-sidebar#onWheelHover"></canvas>

        <div class="tcp-custom-row">
          <div class="tcp-preview" data-tag-sidebar-target="colorPreview"></div>
          <span class="tcp-hex" data-tag-sidebar-target="colorHex">#3b82f6</span>
          <span class="tcp-wcag tcp-wcag--aa" data-tag-sidebar-target="colorWcag">AA</span>
          <button type="button" class="tcp-confirm"
                  data-action="click->tag-sidebar#confirmCustomColor">✓</button>
        </div>
      </div>
    </div>

    <%# Editor pane %>
    <div id="editor-pane"
         class="flex-1 min-w-0 flex flex-col relative"
         data-controller="codemirror text-format stats-panel typewriter jump-to-line wikilink"
         data-codemirror-initial-value-value="<%= @revision&.content_markdown.to_s %>"
         data-wikilink-search-url-value="<%= search_notes_path %>"
         data-wikilink-create-promise-url-value="<%= create_from_promise_note_path(@note.slug) %>"
         data-wikilink-current-note-id-value="<%= @note.id %>"
         data-editor-target="editorPane">
      <div id="codemirror-host"
           class="flex-1 min-h-0 overflow-hidden"
           data-codemirror-target="host"
           data-text-format-target="editor"
           data-typewriter-target="editor"></div>

      <%# Wiki-link autocomplete dropdown %>
      <div class="wikilink-dropdown" hidden
           data-wikilink-target="dropdown"></div>

      <%# Stats bar %>
      <div class="editor-stats-bar flex items-center gap-4 px-4 py-1 flex-shrink-0"
           data-stats-panel-target="bar">
        <span data-stats-panel-target="words">0 palavras</span>
        <span data-stats-panel-target="lines">0 linhas</span>
        <span data-stats-panel-target="position">L1, C1</span>
      </div>
    </div>

    <%# Divider %>
    <div class="pane-divider pane-divider--draggable"
         data-editor-target="previewResizeHandle"
         data-action="pointerdown->editor#startPreviewResize"></div>

    <%# Preview pane %>
    <div id="preview-pane"
         class="flex-1 min-w-0 overflow-y-auto flex flex-col"
         data-controller="preview"
         data-editor-target="previewPane"
         data-action="scroll->preview#scroll">
      <section data-ai-review-target="workspace"
               class="hidden flex-1 min-h-0 flex-col bg-[var(--theme-bg-secondary)]">
        <div data-ai-review-target="configNotice"
             class="hidden flex-1 overflow-y-auto p-5">
          <div class="rounded-lg border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] p-5">
            <h3 class="text-base font-semibold mb-2">IA não configurada</h3>
            <p class="text-sm text-[var(--theme-text-muted)] mb-4">
              Configure ao menos um provider por ENV. Exemplos:
            </p>
            <div class="grid grid-cols-1 gap-4 text-sm">
              <pre class="bg-[var(--theme-code-bg)] p-3 rounded overflow-x-auto">OLLAMA_API_BASE=http://AIrch:11434
OLLAMA_MODEL=qwen2.5:1.5b
AI_PROVIDER=ollama
AI_ENABLED_PROVIDERS=ollama</pre>
            </div>
          </div>
        </div>

        <div data-ai-review-target="processingBox"
             class="hidden flex-1 items-center justify-center p-6">
          <div class="w-full max-w-md rounded-xl border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] p-6 shadow-lg">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full border-2 border-[var(--theme-accent)] border-t-transparent animate-spin"></div>
              <div>
                <p class="text-sm font-semibold text-[var(--theme-text-primary)]">Processando com IA</p>
                <p data-ai-review-target="processingState" class="text-sm text-[var(--theme-text-secondary)]">Na fila</p>
              </div>
            </div>
            <p data-ai-review-target="processingProvider" class="mt-4 text-sm text-[var(--theme-text-muted)]">IA</p>
            <p data-ai-review-target="processingHint" class="mt-2 text-xs text-[var(--theme-text-secondary)]">Processamento assíncrono em andamento.</p>
            <p data-ai-review-target="processingMeta" class="mt-2 text-xs text-[var(--theme-text-muted)]">Aguardando execução...</p>
            <p data-ai-review-target="processingError" class="hidden mt-2 text-xs text-amber-300"></p>
            <div class="mt-5 flex justify-end">
              <button type="button"
                      class="rounded-md border border-[var(--theme-border)] px-3 py-1.5 text-sm text-[var(--theme-text-secondary)] hover:bg-[var(--theme-bg-secondary)]"
                      data-action="click->ai-review#cancelProcessing">
                Cancelar
              </button>
            </div>
          </div>
        </div>

        <div data-ai-review-target="resultBox"
             class="hidden flex-1 min-h-0 flex-col">
          <div class="border-b border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-3">
            <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--theme-text-faint)]">Sugerido</p>
          </div>
          <div class="flex-1 min-h-0 overflow-y-auto">
            <textarea data-ai-review-target="correctedText"
                      class="hidden"
                      spellcheck="false"
                      data-action="input->ai-review#proposalChanged change->ai-review#proposalChanged"></textarea>
            <div class="bg-[var(--theme-bg-primary)] px-5 py-4">
              <div data-ai-review-target="proposalDiff"
                   contenteditable="true"
                   spellcheck="false"
                   data-action="input->ai-review#proposalEditorChanged blur->ai-review#proposalEditorChanged"
                   class="min-h-full whitespace-pre-wrap font-mono text-sm leading-relaxed text-[var(--theme-text-primary)] outline-none"></div>
            </div>
          </div>

          <div data-ai-review-target="translationMeta"
               class="hidden border-t border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-4">
            <p data-ai-review-target="translationSummary" class="text-sm text-[var(--theme-text-secondary)]">
              Uma nova nota irma sera criada a partir desta traducao.
            </p>
            <label class="mt-3 block" for="ai-translation-title">
              <span class="mb-1 block text-xs font-medium uppercase tracking-wide text-[var(--theme-text-muted)]">
                Titulo da nova nota
              </span>
              <input type="text"
                     id="ai-translation-title"
                     data-ai-review-target="translationTitle"
                     class="w-full rounded-md border border-[var(--theme-border)] bg-[var(--theme-bg-primary)] px-3 py-2 text-sm text-[var(--theme-text-primary)] outline-none focus:border-[var(--theme-accent)]"
                     placeholder="Titulo da nota traduzida">
            </label>
          </div>

          <footer class="flex items-center justify-between gap-3 border-t border-[var(--theme-border)] bg-[var(--theme-bg-secondary)] px-5 py-4">
            <button type="button"
                    data-ai-review-target="declineButton"
                    data-action="click->ai-review#close"
                    class="rounded-md border border-[var(--theme-border)] px-4 py-2 text-sm text-[var(--theme-text-secondary)] hover:bg-[var(--theme-bg-primary)]">
              Fechar
            </button>
            <button type="button"
                    data-ai-review-target="acceptButton"
                    data-action="click->ai-review#accept"
                    class="rounded-md bg-[var(--theme-accent)] px-4 py-2 text-sm text-[var(--theme-accent-text)] hover:bg-[var(--theme-accent-hover)]">
              Aplicar
            </button>
          </footer>
        </div>
      </section>

      <div data-ai-review-target="previewShell" class="flex flex-1 min-h-0 flex-col">
        <div class="preview-prose flex-1"
             data-editor-target="previewContent"
             data-preview-target="output">
          <p style="color: var(--theme-text-faint); font-style: italic;">Comece a digitar para ver o preview...</p>
        </div>

        <div class="preview-context-resize-handle"
             data-editor-target="contextResizeHandle"
             data-action="pointerdown->editor#startContextResize"></div>

        <section class="note-context-panel"
                 data-editor-target="contextPanel">
          <div class="preview-layout-toolbar">
            <label class="preview-layout-toolbar__field">
              <span>Rodape</span>
              <select data-editor-target="contextMode" data-action="change->editor#updateContextMode">
                <option value="graph">Grafo</option>
                <option value="backlinks">Backlinks</option>
                <option value="hidden">Oculto</option>
              </select>
            </label>
          </div>

          <div class="note-graph-panel"
               data-editor-target="graphPanel">
            <div class="note-graph-embed"
               data-controller="graph"
               data-graph-data-url-value="<%= api_graph_path %>"
               data-graph-initial-focused-node-id-value="<%= @note.id %>"
               data-graph-embedded-mode-value="true">
              <div class="note-graph-embed__meta hidden" data-graph-target="meta">Carregando grafo...</div>
              <div class="note-graph-embed__canvas">
                <div class="note-graph-embed__host" data-graph-target="graphHost"></div>
                <div class="note-graph-embed__tooltip-layer" data-graph-target="tooltipLayer"></div>
              </div>
              <div class="note-graph-embed__empty hidden" data-graph-target="empty">
                Nenhum vizinho ficou visivel no grafo.
              </div>
              <div class="note-graph-embed__error hidden" data-graph-target="error"></div>
            </div>
          </div>

          <section class="backlinks-panel hidden"
                   data-editor-target="backlinksPanel">
            <%= render "notes/backlinks_content", note: @note %>
          </section>
        </section>
      </div>
    </div>
  </div>

  <%# ── Connection lost banner ──────────────────────────── %>
  <div id="offline-banner"
       class="hidden fixed bottom-0 left-0 right-0 px-4 py-2 text-sm text-center z-50"
       data-controller="connection-monitor"
       data-connection-monitor-target="banner">
    ⚠ Conexão perdida — as alterações serão salvas ao reconectar
  </div>

  <%# ── Find/Replace dialog ─────────────────────────────── %>
  <div id="find-replace-dialog"
       class="hidden fixed top-14 right-4 z-40 w-80 editor-dialog"
       data-controller="find-replace"
       data-find-replace-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Localizar / Substituir</span>
      <button class="toolbar-btn !p-0.5" data-action="click->find-replace#close">✕</button>
    </div>
    <div class="p-4 space-y-3">
      <div class="flex gap-2">
        <input type="text"
               placeholder="Localizar..."
               class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
               data-find-replace-target="findInput"
               data-action="input->find-replace#search keydown->find-replace#handleFindKey">
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#previous" title="Anterior">↑</button>
        <button class="editor-dialog-btn px-2 py-1" data-action="click->find-replace#next" title="Próximo">↓</button>
      </div>
      <div class="flex gap-3 items-center">
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="caseSensitive"> Maiúsc.
        </label>
        <label class="flex items-center gap-1.5 text-xs cursor-pointer" style="color: var(--theme-text-muted)">
          <input type="checkbox" data-find-replace-target="useRegex"> Regex
        </label>
        <span class="ml-auto text-xs" style="color: var(--theme-text-faint)" data-find-replace-target="matchCount">—</span>
      </div>
      <input type="text"
             placeholder="Substituir por..."
             class="editor-dialog-input w-full px-3 py-1.5 text-sm"
             data-find-replace-target="replaceInput">
      <div class="flex gap-2">
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceCurrent">Substituir</button>
        <button class="editor-dialog-btn flex-1 px-3 py-1.5"
                data-action="click->find-replace#replaceAll">Subst. Tudo</button>
      </div>
    </div>
  </div>

  <%# ── Jump to Line dialog ────────────────────────────── %>
  <div id="jump-to-line-dialog"
       class="hidden fixed top-14 right-4 z-40 w-56 editor-dialog"
       data-jump-to-line-target="dialog">
    <div class="editor-dialog-header flex items-center justify-between px-4 py-3">
      <span class="text-sm font-medium">Ir para Linha</span>
      <button class="toolbar-btn !p-0.5" data-action="click->jump-to-line#close">✕</button>
    </div>
    <div class="p-4 flex gap-2">
      <input type="number" min="1"
             placeholder="Número..."
             class="editor-dialog-input flex-1 px-3 py-1.5 text-sm"
             data-jump-to-line-target="lineInput"
             data-action="keydown->jump-to-line#handleKey">
      <button class="rounded px-3 py-1.5 text-xs text-white cursor-pointer"
              style="background: var(--theme-accent);"
              data-action="click->jump-to-line#jump">Ir</button>
    </div>
  </div>

  <dialog
    data-ai-review-target="historyDialog"
    class="w-[92vw] max-w-3xl max-h-[75vh] p-0 rounded-lg shadow-xl bg-[var(--theme-bg-primary)] text-[var(--theme-text-primary)] backdrop:bg-black/50 border border-[var(--theme-border)]"
  >
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[var(--theme-border)]">
        <div>
          <h2 class="text-lg font-semibold">Histórico de IA</h2>
          <p class="text-xs text-[var(--theme-text-muted)]" data-ai-review-target="historyStatus">Carregando execuções recentes...</p>
        </div>
        <div class="flex items-center gap-2">
          <button type="button"
                  class="toolbar-btn"
                  title="Atualizar histórico de IA"
                  data-action="click->ai-review#refreshHistory">
            ↻
          </button>
          <button class="toolbar-btn !p-0.5" data-action="click->ai-review#closeHistory">✕</button>
        </div>
      </div>

      <div class="p-6 overflow-y-auto">
        <div class="mb-4 flex flex-wrap gap-2">
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="shell"
                  data-action="click->ai-review#selectHistoryFilter">
            Shell
          </button>
          <button type="button"
                  class="ai-history-filter is-active"
                  data-ai-review-target="historyFilter"
                  data-filter-value="all"
                  data-action="click->ai-review#selectHistoryFilter">
            Todas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="active"
                  data-action="click->ai-review#selectHistoryFilter">
            Ativas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="failed"
                  data-action="click->ai-review#selectHistoryFilter">
            Falhas
          </button>
          <button type="button"
                  class="ai-history-filter"
                  data-ai-review-target="historyFilter"
                  data-filter-value="succeeded"
                  data-action="click->ai-review#selectHistoryFilter">
            Concluídas
          </button>
        </div>
        <p class="hidden text-sm text-[var(--theme-text-muted)]" data-ai-review-target="historyEmpty">
          Nenhuma execução de IA registrada para esta nota.
        </p>
        <div class="space-y-3" data-ai-review-target="historyList"></div>
      </div>
    </div>
  </dialog>

</div>
