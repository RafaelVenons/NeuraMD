<div class="hidden fixed inset-0 z-50 flex items-start justify-center bg-black/65 px-4 py-16"
     data-note-finder-target="dialog"
     data-action="click.self->note-finder#close">
  <div class="note-finder-panel w-full max-w-2xl overflow-hidden rounded-xl border shadow-2xl">
    <div class="note-finder-panel__header px-4 py-3">
      <div class="flex items-center gap-3">
        <input type="search"
               class="note-finder-input flex-1"
               placeholder="Buscar notas por titulo ou conteudo..."
               data-note-finder-target="input"
               data-action="input->note-finder#search keydown->note-finder#handleInputKeydown">
        <label class="note-finder-regex">
          <input type="checkbox"
                 data-note-finder-target="regex"
                 data-action="change->note-finder#toggleRegex">
          <span>Regex</span>
        </label>
      </div>
      <p class="note-finder-status mt-2 text-xs" data-note-finder-target="status">
        Digite para buscar por titulo ou conteudo
      </p>
    </div>
    <div class="note-finder-panel__results max-h-[28rem] overflow-y-auto"
         data-note-finder-target="results"></div>
  </div>
</div>
