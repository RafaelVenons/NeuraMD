#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${PLAYWRIGHT_BASE_URL:-http://127.0.0.1:3000}"
HEADED=0
DEBUG=0
ARGS=()

while (($#)); do
  case "$1" in
    --base-url)
      BASE_URL="${2:?missing value for --base-url}"
      shift 2
      ;;
    --headed)
      HEADED=1
      shift
      ;;
    --debug)
      DEBUG=1
      shift
      ;;
    --help|-h)
      cat <<'EOF'
Uso:
  bin/e2e-local [--base-url URL] [--headed] [--debug] [args do playwright]

Comportamento:
  - força PLAYWRIGHT_NO_WEBSERVER=1
  - usa http://127.0.0.1:3000 por padrão
  - passa o restante dos argumentos para `npx playwright test`

Exemplos:
  bin/e2e-local
  bin/e2e-local e2e/imported-note-visibility.spec.js --reporter=line
  bin/e2e-local --headed e2e/typewriter-cursor-visibility.spec.js
  bin/e2e-local --base-url http://127.0.0.1:3101 e2e/new-specs-note-navigation.spec.js
EOF
      exit 0
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done

export PLAYWRIGHT_NO_WEBSERVER=1
export PLAYWRIGHT_BASE_URL="$BASE_URL"

CMD=(npx playwright test)

if [[ $HEADED -eq 1 ]]; then
  CMD+=(--headed)
fi

if [[ $DEBUG -eq 1 ]]; then
  CMD+=(--debug)
fi

CMD+=("${ARGS[@]}")

echo "==> PLAYWRIGHT_NO_WEBSERVER=1"
echo "==> PLAYWRIGHT_BASE_URL=$PLAYWRIGHT_BASE_URL"
exec "${CMD[@]}"
