#!/usr/bin/env bash
set -euo pipefail

AIRCH_HOST="rafael@AIrch.local"
AIRCH_DIR="~/projects/NeuraMD"
MISE="/home/rafael/.local/bin/mise"

echo "==> Syncing local changes to AIrch..."
rsync -az --delete \
  --exclude='.git' \
  --exclude='node_modules' \
  --exclude='tmp' \
  --exclude='log' \
  --exclude='.env' \
  --exclude='storage' \
  ~/projects/NeuraMD/ "${AIRCH_HOST}:${AIRCH_DIR}/"

echo "==> Migrating test DB on AIrch..."
ssh "${AIRCH_HOST}" "cd ${AIRCH_DIR} && RAILS_ENV=test ${MISE} exec -- bin/rails db:migrate 2>&1" | tail -3

echo "==> Running specs on AIrch..."
ssh "${AIRCH_HOST}" "cd ${AIRCH_DIR} && ${MISE} exec -- bundle exec rspec $*"
