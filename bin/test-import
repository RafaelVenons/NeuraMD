#!/usr/bin/env bash
# Dry-run CLI for the new TOC-driven import pipeline.
# Usage: bin/test-import PATH [THRESHOLD]
#   PATH:      a PDF file, or a directory containing PDFs
#   THRESHOLD: density-lines per note (default 30)
#
# Environment overrides:
#   THRESHOLD=50 bin/test-import spec/fixtures/files/
#   SAVE_MARKDOWN=1 bin/test-import my.pdf   # writes markdown to /tmp/
#   PATTERN='**/*.pdf' bin/test-import dir/
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "Usage: bin/test-import PATH [THRESHOLD]"
  exit 1
fi

PATH_ARG="$1"
THRESHOLD="${2:-${THRESHOLD:-30}}"

cd "$(dirname "$0")/.."
exec bin/rails "import:test[${PATH_ARG},${THRESHOLD}]"
