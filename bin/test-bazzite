#!/usr/bin/env bash
set -euo pipefail

REMOTE_HOST="venom@bazzite.local"
REMOTE_DIR="~/projects/NeuraMD"
MISE="/home/venom/.local/bin/mise"

echo "==> Syncing local changes to bazzite..."
rsync -az --delete \
  --exclude='.git' \
  --exclude='node_modules' \
  --exclude='tmp' \
  --exclude='log' \
  --exclude='.env' \
  --exclude='storage' \
  ~/projects/NeuraMD/ "${REMOTE_HOST}:${REMOTE_DIR}/"

echo "==> Migrating test DB on bazzite..."
ssh "${REMOTE_HOST}" "cd ${REMOTE_DIR} && RAILS_ENV=test ${MISE} exec -- bin/rails db:migrate 2>&1" | tail -3

echo "==> Running specs on bazzite..."
ssh "${REMOTE_HOST}" "cd ${REMOTE_DIR} && ${MISE} exec -- bundle exec rspec $*"
