# Rails
SECRET_KEY_BASE=your_secret_key_base_here
RAILS_MASTER_KEY=your_master_key_here

# PostgreSQL
POSTGRES_USER=neuramd
POSTGRES_PASSWORD=neuramd
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Active Record Encryption — generate with: bin/rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Storage: local | amazon | minio | google
STORAGE_SERVICE=local

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers (optional)
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_PROVIDER=ollama
AI_ENABLED_PROVIDERS=ollama
OLLAMA_API_BASE=http://AIrch:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_ROUTE_GRAMMAR_SHORT_MODEL=qwen2.5:0.5b
OLLAMA_ROUTE_GRAMMAR_LONG_MODEL=qwen2.5:1.5b
OLLAMA_ROUTE_GRAMMAR_SHORT_MAX_CHARS=800
OLLAMA_ROUTE_SUGGEST_SHORT_MODEL=qwen2:1.5b
OLLAMA_ROUTE_SUGGEST_LONG_MODEL=qwen2.5:3b
OLLAMA_ROUTE_SUGGEST_SHORT_MAX_CHARS=900
OLLAMA_ROUTE_REWRITE_SHORT_MODEL=qwen2.5:1.5b
OLLAMA_ROUTE_REWRITE_LONG_MODEL=llama3.2:3b
OLLAMA_ROUTE_REWRITE_SHORT_MAX_CHARS=900
OLLAMA_ROUTE_TRANSLATE_PT_EN_SHORT_MODEL=qwen2:1.5b
OLLAMA_ROUTE_TRANSLATE_PT_EN_LONG_MODEL=qwen2.5:3b
OLLAMA_ROUTE_TRANSLATE_PT_EN_SHORT_MAX_CHARS=1200
OLLAMA_ROUTE_TRANSLATE_EN_PT_SHORT_MODEL=qwen2:1.5b
OLLAMA_ROUTE_TRANSLATE_EN_PT_LONG_MODEL=qwen2.5:3b
OLLAMA_ROUTE_TRANSLATE_EN_PT_SHORT_MAX_CHARS=1200
OLLAMA_ROUTE_TRANSLATE_TO_EN_MODEL=qwen2:1.5b
OLLAMA_ROUTE_TRANSLATE_GENERAL_MODEL=qwen2.5:3b
OLLAMA_OPEN_TIMEOUT=5
OLLAMA_READ_TIMEOUT=7200
OLLAMA_WRITE_TIMEOUT=30
AI_REMOTE_JOB_THREADS=1
AI_REMOTE_JOB_CONCURRENCY=1
OLLAMA_RUNNING_STUCK_AFTER=10800
OLLAMA_QUEUED_STUCK_AFTER=21600
OLLAMA_RETRY_GRACE_PERIOD=600
AI_WATCHER_POLL_INTERVAL=2
AI_WATCHER_HEALTH_TIMEOUT=2
AI_WATCHER_REQUEST_TIMEOUT=180
AI_WATCHER_TOOLTIP_JOBS=5

# TTS Providers (optional)
TTS_ELEVENLABS_API_KEY=
TTS_FISH_AUDIO_API_KEY=

# Shared mount for future local AI/TTS tooling
# Suggested dedicated partition mounted on the host, then bind-mounted where needed.
SHARED_AI_ROOT=/mnt/neuramd-share
KOKORO_ROOT=/mnt/neuramd-share/kokoro
MFA_ROOT=/mnt/neuramd-share/mfa
TTS_RENDER_ROOT=/mnt/neuramd-share/tts/rendered
ALIGNMENT_ROOT=/mnt/neuramd-share/alignments
KOKORO_IMAGE=ghcr.io/remsky/kokoro-fastapi-cpu:v0.2.4
MFA_IMAGE=mmcauliffe/montreal-forced-aligner:latest
KOKORO_PORT=8880
KOKORO_BIND=127.0.0.1
OLLAMA_API_BASE=http://AIrch:11434
OLLAMA_MODEL=qwen3.5:4b
AI_WATCHER_POLL_INTERVAL=2
AI_WATCHER_HEALTH_TIMEOUT=2
AI_WATCHER_REQUEST_TIMEOUT=180
AI_WATCHER_TOOLTIP_JOBS=5
