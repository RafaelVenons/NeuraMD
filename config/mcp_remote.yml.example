# Remote MCP Gateway whitelist + scope map.
#
# Each entry maps an MCP tool_name (as exposed in the protocol) to:
#   class  — the Ruby class to load (must respond to MCP::Tool interface)
#   scope  — the minimum McpAccessToken scope required to invoke it
#
# Tools NOT listed here are NOT exposed remotely. Stdio tentacles still
# get the full Mcp::Tools.all set; this file only governs the HTTP gate.
#
# Copy to config/mcp_remote.yml and adjust before exposing the gateway.
tools:
  search_notes:
    class: Mcp::Tools::SearchNotesTool
    scope: read
  read_note:
    class: Mcp::Tools::ReadNoteTool
    scope: read
  list_tags:
    class: Mcp::Tools::ListTagsTool
    scope: read
  notes_by_tag:
    class: Mcp::Tools::NotesByTagTool
    scope: read
  note_graph:
    class: Mcp::Tools::NoteGraphTool
    scope: read
  recent_changes:
    class: Mcp::Tools::RecentChangesTool
    scope: read
  find_anemic_notes:
    class: Mcp::Tools::FindAnemicNotesTool
    scope: read

  # Aggregate read-only views composed from existing queries — cheaper
  # than the multi-call dance an agent typically runs at session open.
  acervo_snapshot:
    class: Mcp::Tools::AcervoSnapshotTool
    scope: read
  agent_status:
    class: Mcp::Tools::AgentStatusTool
    scope: read
  create_note:
    class: Mcp::Tools::CreateNoteTool
    scope: write
  update_note:
    class: Mcp::Tools::UpdateNoteTool
    scope: write
  patch_note:
    class: Mcp::Tools::PatchNoteTool
    scope: write
  manage_property:
    class: Mcp::Tools::ManagePropertyTool
    scope: write
  import_markdown:
    class: Mcp::Tools::ImportMarkdownTool
    scope: write
  merge_notes:
    class: Mcp::Tools::MergeNotesTool
    scope: write
  bulk_remove_tag:
    class: Mcp::Tools::BulkRemoveTagTool
    scope: write

  # Conversational bridge for remote agents. Both tools require the
  # token to have an agent_note bound (issue with AGENT_SLUG=<slug>).
  # Sender identity is locked to the token's agent_note (no spoofing);
  # recipient must be a note carrying an `agente-*` tag (no broadcast
  # to humans / arbitrary notes). This is the supported way for an
  # external client to participate in the agent fabric without being
  # granted the raw mesh tools below.
  talk_to_agent:
    class: Mcp::Tools::TalkToAgentTool
    scope: tentacle
  read_my_inbox:
    class: Mcp::Tools::ReadMyInboxTool
    scope: tentacle

  # Raw agent-mesh tools — disabled by default. They accept arbitrary
  # from_slug / to_slug / parent_slug, so a write+tentacle leak with
  # these enabled lets external clients spoof inbox messages, spawn
  # tentacles, and route the human to any agent. Prefer the bounded
  # talk_to_manager / read_manager_replies pair above unless you
  # specifically need the unrestricted surface.
  # send_agent_message:
  #   class: Mcp::Tools::SendAgentMessageTool
  #   scope: tentacle
  # read_agent_inbox:
  #   class: Mcp::Tools::ReadAgentInboxTool
  #   scope: tentacle
  # spawn_child_tentacle:
  #   class: Mcp::Tools::SpawnChildTentacleTool
  #   scope: tentacle
  # activate_tentacle_session:
  #   class: Mcp::Tools::ActivateTentacleSessionTool
  #   scope: tentacle
  # route_human_to:
  #   class: Mcp::Tools::RouteHumanToTool
  #   scope: tentacle

# Per-token rate limit. Each McpAccessToken is throttled separately.
# Adjust here or via NEURAMD_MCP_RATE_LIMIT_PER_MIN env var.
rate_limit_per_min: 60

# Per-call timeout (seconds). Long-running tools should be split or
# moved to a job queue rather than raised here.
call_timeout_seconds: 30
